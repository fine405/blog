---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { ArrowRight, ArrowUpRight, CalendarDays, Clock3 } from '@lucide/astro';
import { fromMarkdown } from 'mdast-util-from-markdown';
import { getBlogDates } from '../utils/git-dates';
import { calculateReadingTime } from '../utils/reading-time';

type MarkdownNode = {
  type: string;
  value?: string;
  alt?: string;
  children?: MarkdownNode[];
};

const nodeToText = (node: MarkdownNode): string => {
  if (typeof node.value === 'string') return node.value;
  if (node.type === 'image') return node.alt || '';
  return node.children?.map(nodeToText).join('') || '';
};

const getFirstParagraph = (markdown: string) => {
  const tree = fromMarkdown(markdown) as MarkdownNode;
  const paragraph = tree.children?.find((node) => node.type === 'paragraph');
  return paragraph ? nodeToText(paragraph).replace(/\s+/g, ' ').trim() : '';
};

const rawPosts = await getCollection('blog', ({ data }) => {
  return import.meta.env.DEV || !data.draft;
});

const allPosts = rawPosts.map((post) => {
  const { date, updatedDate } = getBlogDates(
    post.slug,
    post.data.date,
    post.data.updatedDate,
    post.data.disableUpdateDate
  );
  return { ...post, date, updatedDate };
}).sort((a, b) => b.date.valueOf() - a.date.valueOf());

const posts = allPosts.slice(0, 5);
const featuredPost = posts[0];
const remainingPosts = posts.slice(1);
const featuredExcerpt = getFirstParagraph(featuredPost.body) || featuredPost.data.description;
const featuredReadingTime = calculateReadingTime(featuredPost.body);
const formatDate = (date: Date) => new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
}).format(date);
---

<BaseLayout
  title="Fine 的技术博客"
  description="记录 AI 工程、TypeScript、架构设计与效率工具实战，分享可复用的开发经验与思考。"
  tags={['AI', 'TypeScript', '架构设计', '工程实践', '技术博客']}
>
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-copy">
      <p class="eyebrow"><span aria-hidden="true"></span> AI × SOFTWARE ENGINEERING</p>
      <h1 id="hero-title">在代码与智能之间，<br /><em>记录值得复用的思考。</em></h1>
      <p class="hero-description">
        你好，我是 Fine。这里分享 AI 工程、软件架构与效率工具的真实实践，把复杂问题拆成清晰、可执行的方法。
      </p>
      <div class="hero-actions">
        <a href="/blog" class="button button-primary">
          浏览全部文章
          <ArrowRight size={17} stroke-width={1.9} aria-hidden="true" />
        </a>
        <a href="/about" class="button button-secondary">了解我在做什么</a>
      </div>
    </div>
  </section>

  <section class="latest-posts" aria-labelledby="latest-title">
    <div class="section-heading" data-reveal>
      <div>
        <p class="section-kicker">RECENT WRITING</p>
        <h2 id="latest-title">最新文章</h2>
      </div>
      <a href="/blog" class="text-link">
        查看全部
        <ArrowRight size={16} stroke-width={1.8} aria-hidden="true" />
      </a>
    </div>

    <a href={`/blog/${featuredPost.slug}`} class="featured-post liquid-glass" data-reveal>
      <article class="featured-main">
        <div class="featured-meta">
          <span class="latest-label">最新发布</span>
          <time datetime={featuredPost.date.toISOString()}>
            <CalendarDays size={14} stroke-width={1.8} aria-hidden="true" />
            {formatDate(featuredPost.date)}
          </time>
          <span>
            <Clock3 size={14} stroke-width={1.8} aria-hidden="true" />
            阅读约 {featuredReadingTime} 分钟
          </span>
        </div>
        <h3>{featuredPost.data.title}</h3>
      </article>

      <div class="featured-summary">
        <p>{featuredExcerpt}</p>
        <div class="featured-footer">
          <div class="featured-tags" aria-label="文章标签">
            {featuredPost.data.tags?.slice(0, 3).map((tag) => <span>{tag}</span>)}
          </div>
          <span class="featured-read">
            阅读全文
            <ArrowUpRight size={18} stroke-width={1.8} aria-hidden="true" />
          </span>
        </div>
      </div>
    </a>

    <ol class="post-list">
      {remainingPosts.map((post, index) => (
        <li data-reveal style={`--reveal-delay: ${index * 55}ms`}>
          <a href={`/blog/${post.slug}`} class="liquid-glass">
            <span class="post-number" aria-hidden="true">{String(index + 2).padStart(2, '0')}</span>
            <article>
              <div class="post-meta">
                <span>{post.data.tags?.[0] || '技术思考'}</span>
                <time datetime={post.date.toISOString()}>
                  <Clock3 size={14} stroke-width={1.8} aria-hidden="true" />
                  {formatDate(post.date)}
                </time>
              </div>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
            </article>
            <span class="post-arrow" aria-hidden="true">
              <ArrowUpRight size={19} stroke-width={1.8} />
            </span>
          </a>
        </li>
      ))}
    </ol>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: min(510px, calc(100vh - 13rem));
    padding: 2.75rem 0 3.25rem;
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--border);
  }

  .hero-copy {
    width: 100%;
  }

  .eyebrow,
  .section-kicker {
    color: var(--accent-strong);
    font-size: 0.71rem;
    font-weight: 720;
    letter-spacing: 0.17em;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
  }

  .eyebrow span {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 0 0 5px var(--accent-soft);
    animation: dot-breathe 3.2s ease-in-out 1.1s infinite;
  }

  .hero h1 {
    max-width: 1080px;
    margin-top: 1.6rem;
    color: var(--text-primary);
    font-size: clamp(3rem, 6.35vw, 6rem);
    font-weight: 720;
    letter-spacing: -0.065em;
    line-height: 1.08;
  }

  .hero h1 em {
    display: inline-block;
    color: var(--text-secondary);
    font-style: normal;
    font-weight: 560;
    white-space: nowrap;
  }

  .hero-description {
    max-width: 720px;
    margin-top: 1.75rem;
    color: var(--text-secondary);
    font-size: clamp(1rem, 1.55vw, 1.14rem);
    line-height: 1.85;
  }

  .hero-actions {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .button {
    min-height: 46px;
    padding: 0 1.15rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    border: 1px solid transparent;
    border-radius: 15px;
    corner-shape: squircle;
    font-size: 0.9rem;
    font-weight: 650;
    text-decoration: none;
    transition:
      transform 200ms var(--ease-out),
      box-shadow 200ms ease,
      background-color 180ms ease,
      border-color 180ms ease;
  }

  .button:hover {
    transform: translateY(-2px);
  }

  .button:active {
    transform: translateY(0) scale(0.98);
  }

  .button-primary {
    border-color: rgba(255, 255, 255, 0.22);
    background: linear-gradient(145deg, #5b86ee, #3159c5 72%);
    box-shadow:
      0 12px 30px rgba(47, 87, 190, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.4),
      inset 0 -1px 0 rgba(18, 52, 137, 0.35);
    color: #fff;
  }

  [data-theme='dark'] .button-primary {
    background: linear-gradient(145deg, #84a5ff, #5578df 72%);
    color: #071123;
  }

  .button-primary:hover {
    box-shadow:
      0 16px 38px rgba(47, 87, 190, 0.34),
      inset 0 1px 0 rgba(255, 255, 255, 0.46),
      inset 0 -1px 0 rgba(18, 52, 137, 0.3);
  }

  .button-primary :global(svg),
  .text-link :global(svg) {
    transition: transform 220ms var(--ease-out);
  }

  .button-primary:hover :global(svg),
  .text-link:hover :global(svg) {
    transform: translateX(3px);
  }

  .button-secondary {
    border-color: var(--glass-stroke-muted);
    background: var(--glass-fill);
    box-shadow: inset 0 1px 0 var(--glass-highlight), 0 8px 24px rgba(50, 69, 108, 0.08);
    color: var(--text-primary);
    -webkit-backdrop-filter: blur(18px) saturate(1.25);
    backdrop-filter: blur(18px) saturate(1.25);
  }

  .button-secondary:hover {
    border-color: var(--glass-stroke);
    background: var(--glass-fill-strong);
  }

  .hero-copy > .eyebrow,
  .hero-copy > h1,
  .hero-copy > .hero-description,
  .hero-copy > .hero-actions {
    animation: hero-rise 720ms var(--ease-out) both;
  }

  .hero-copy > h1 { animation-delay: 70ms; }
  .hero-copy > .hero-description { animation-delay: 150ms; }
  .hero-copy > .hero-actions { animation-delay: 230ms; }

  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes dot-breathe {
    0%, 100% { box-shadow: 0 0 0 5px var(--accent-soft); }
    50% { box-shadow: 0 0 0 8px transparent; }
  }

  .latest-posts {
    padding: 3.5rem 0 1rem;
  }

  .section-heading {
    margin-bottom: 2.1rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .section-heading h2 {
    margin-top: 0.55rem;
    color: var(--text-primary);
    font-size: clamp(2rem, 3.3vw, 2.9rem);
    font-weight: 690;
    letter-spacing: -0.05em;
  }

  .text-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-secondary);
    font-size: 0.86rem;
    font-weight: 620;
    text-decoration: none;
    transition: color 180ms ease, transform 180ms var(--ease-out);
  }

  .text-link:hover {
    color: var(--text-primary);
    transform: translateX(3px);
  }

  .featured-post {
    padding: clamp(1.8rem, 3vw, 2.4rem);
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.72fr);
    align-items: stretch;
    gap: clamp(2.3rem, 5vw, 4.8rem);
    overflow: hidden;
    border: 1px solid var(--glass-stroke-muted);
    border-radius: var(--radius-xl);
    background: var(--glass-fill);
    color: inherit;
    text-decoration: none;
    transition:
      transform 240ms var(--ease-out),
      border-color 200ms ease,
      background-color 200ms ease,
      box-shadow 240ms ease;
  }

  .featured-post:hover {
    border-color: var(--glass-stroke);
    background: var(--glass-fill-strong);
    box-shadow:
      var(--glass-shadow-hover),
      inset 0 1px 0 var(--glass-highlight);
    transform: translateY(-4px);
  }

  .featured-main {
    display: flex;
    flex-direction: column;
  }

  .featured-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.55rem 1rem;
    color: var(--text-tertiary);
    font-size: 0.73rem;
  }

  .featured-meta time,
  .featured-meta > span:not(.latest-label) {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .latest-label {
    padding: 0.28rem 0.55rem;
    border-radius: 7px;
    background: var(--accent-soft);
    color: var(--accent-strong);
    font-weight: 650;
  }

  .featured-post h3 {
    margin-top: 1.25rem;
    color: var(--text-primary);
    font-size: clamp(1.75rem, 3.3vw, 2.8rem);
    font-weight: 680;
    letter-spacing: -0.045em;
    line-height: 1.3;
    text-wrap: balance;
    transition: color 180ms ease;
  }

  .featured-post:hover h3 {
    color: var(--accent-strong);
  }

  .featured-summary {
    padding-left: clamp(1.5rem, 3vw, 2.5rem);
    display: flex;
    justify-content: space-between;
    flex-direction: column;
    border-left: 1px solid var(--glass-stroke-muted);
  }

  .featured-summary > p {
    color: var(--text-secondary);
    font-size: 0.91rem;
    line-height: 1.85;
  }

  .featured-footer {
    margin-top: 1.5rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
  }

  .featured-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .featured-tags span {
    padding: 0.28rem 0.5rem;
    border: 1px solid var(--glass-stroke-muted);
    border-radius: 9px;
    background: var(--surface-soft);
    color: var(--text-tertiary);
    font-size: 0.66rem;
  }

  .featured-read {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-primary);
    font-size: 0.78rem;
    font-weight: 650;
  }

  .featured-read :global(svg) {
    transition: transform 220ms var(--ease-out);
  }

  .featured-post:hover .featured-read :global(svg) {
    transform: translate(2px, -2px);
  }

  .post-list {
    margin-top: 0.85rem;
    display: grid;
    gap: 0.75rem;
    list-style: none;
  }

  .post-list li {
    border: 0;
  }

  .post-list a {
    padding: 1.65rem;
    display: grid;
    grid-template-columns: 54px minmax(0, 1fr) 42px;
    align-items: center;
    gap: 1.25rem;
    overflow: hidden;
    border: 1px solid var(--glass-stroke-muted);
    border-radius: var(--radius-md);
    background: var(--glass-fill);
    color: inherit;
    text-decoration: none;
    transition:
      transform 220ms var(--ease-out),
      border-color 180ms ease,
      background-color 180ms ease,
      box-shadow 220ms ease;
  }

  .post-list a:hover {
    border-color: var(--glass-stroke);
    background: var(--glass-fill-strong);
    box-shadow:
      var(--glass-shadow-hover),
      inset 0 1px 0 var(--glass-highlight);
    transform: translateY(-3px);
  }

  .post-number {
    color: var(--text-tertiary);
    font-size: 0.72rem;
    font-variant-numeric: tabular-nums;
    font-weight: 660;
    letter-spacing: 0.08em;
  }

  .post-meta {
    margin-bottom: 0.6rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    color: var(--text-tertiary);
    font-size: 0.74rem;
    font-weight: 580;
  }

  .post-meta > span {
    color: var(--accent-strong);
  }

  .post-meta time {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .post-list h3 {
    color: var(--text-primary);
    font-size: clamp(1.08rem, 1.8vw, 1.32rem);
    font-weight: 650;
    letter-spacing: -0.025em;
    line-height: 1.45;
    transition: color 180ms ease;
  }

  .post-list a:hover h3 {
    color: var(--accent-strong);
  }

  .post-list article > p {
    max-width: 850px;
    margin-top: 0.55rem;
    display: -webkit-box;
    overflow: hidden;
    color: var(--text-secondary);
    font-size: 0.88rem;
    line-height: 1.7;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .post-arrow {
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border);
    border-radius: 11px;
    color: var(--text-tertiary);
    transition:
      color 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease,
      transform 220ms var(--ease-out);
  }

  .post-list a:hover .post-arrow {
    border-color: transparent;
    background: var(--accent-soft);
    color: var(--accent-strong);
    transform: rotate(4deg) translate(2px, -2px);
  }

  @media (max-width: 900px) {
    .hero {
      min-height: auto;
      padding-top: 3rem;
    }

    .hero-copy {
      max-width: 820px;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 1.75rem 0 3.25rem;
    }

    .hero h1 {
      margin-top: 1.25rem;
      font-size: clamp(2.65rem, 13.2vw, 4rem);
      line-height: 1.12;
    }

    .hero h1 em {
      display: inline;
      white-space: normal;
    }

    .hero-description {
      margin-top: 1.35rem;
      font-size: 0.98rem;
      line-height: 1.75;
    }

    .hero-actions {
      align-items: stretch;
      flex-direction: column;
    }

    .button {
      width: 100%;
    }

    .latest-posts {
      padding-top: 3.25rem;
    }

    .section-heading {
      align-items: flex-start;
    }

    .featured-post {
      padding: 1.45rem;
      grid-template-columns: 1fr;
      gap: 1.35rem;
    }

    .featured-post:hover {
      transform: translateY(-2px);
    }

    .featured-post h3 {
      font-size: clamp(1.55rem, 8vw, 2.2rem);
    }

    .featured-summary {
      padding: 1.25rem 0 0;
      border-top: 1px solid var(--border);
      border-left: 0;
    }

    .featured-footer {
      align-items: flex-start;
      flex-direction: column;
    }

    .post-list a {
      padding: 1.25rem;
      grid-template-columns: minmax(0, 1fr) 36px;
      gap: 0.8rem;
    }

    .post-list a:hover {
      transform: translateY(-2px);
    }

    .post-number {
      display: none;
    }

    .post-meta {
      flex-wrap: wrap;
      gap: 0.45rem 0.8rem;
    }

    .post-list article > p {
      -webkit-line-clamp: 3;
    }
  }
</style>
