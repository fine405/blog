---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import {
  ArrowLeft,
  CalendarDays,
  ChevronUp,
  Clock3,
  ListTree,
  RefreshCw,
} from '@lucide/astro';
import ImageLightbox from '../../components/ImageLightbox.astro';
import { getBlogDates } from '../../utils/git-dates';
import { calculateReadingTime } from '../../utils/reading-time';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => {
    return import.meta.env.DEV || !data.draft;
  });
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
const tocHeadings = headings.filter(({ depth }) => depth === 2 || depth === 3);

const { date, updatedDate } = getBlogDates(
  post.slug,
  post.data.date,
  post.data.updatedDate,
  post.data.disableUpdateDate
);

const readingTime = calculateReadingTime(post.body);
const coverAlt = post.data.cover?.alt || `${post.data.title} 封面图`;
const fallbackDate = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
---

<BaseLayout
  title={`${post.data.title} - Fine`}
  description={post.data.description}
  image={post.data.cover?.url}
  imageAlt={coverAlt}
  type="article"
  schemaTitle={post.data.title}
  publishedTime={date}
  modifiedTime={updatedDate}
  tags={post.data.tags}
  backgroundMotion={false}
>
  <div class="reading-progress" aria-hidden="true"><span id="reading-progress-bar"></span></div>

  {tocHeadings.length > 0 && (
    <aside class="article-toc liquid-glass" data-article-toc aria-label="文章目录">
      <button
        class="toc-toggle"
        type="button"
        aria-controls="article-toc-panel"
        aria-expanded="false"
      >
        <span class="toc-toggle-icon" aria-hidden="true">
          <ListTree size={17} stroke-width={1.9} />
        </span>
        <span>目录</span>
        <span class="toc-toggle-progress" data-toc-progress-text>0%</span>
        <span class="toc-toggle-chevron" aria-hidden="true">
          <ChevronUp size={15} stroke-width={2} />
        </span>
      </button>

      <div class="toc-panel" id="article-toc-panel">
        <div class="toc-heading">
          <div>
            <p>ON THIS PAGE</p>
            <h2>文章目录</h2>
          </div>
          <span>{tocHeadings.length} 项</span>
        </div>

        <nav class="toc-nav" aria-label="文章章节">
          <ol class="toc-list">
            {tocHeadings.map((heading, index) => (
              <li>
                <a
                  href={`#${heading.slug}`}
                  class:list={[
                    'toc-link',
                    `toc-depth-${heading.depth}`,
                    { 'is-active': index === 0 },
                  ]}
                  data-toc-link
                  data-heading-id={heading.slug}
                  aria-current={index === 0 ? 'location' : undefined}
                  title={heading.text}
                >
                  <span class="toc-link-marker" aria-hidden="true"></span>
                  <span class="toc-link-label">{heading.text}</span>
                </a>
              </li>
            ))}
          </ol>
        </nav>

        <div class="toc-progress">
          <div class="toc-progress-meta">
            <span>阅读进度</span>
            <output data-toc-progress-text>0%</output>
          </div>
          <span class="toc-progress-track" aria-hidden="true">
            <span data-toc-progress-fill></span>
          </span>
        </div>
      </div>
    </aside>
  )}

  <article class="post">
    <a href="/blog" class="back-link">
      <ArrowLeft size={16} stroke-width={1.8} aria-hidden="true" />
      返回文章列表
    </a>

    <header class="post-header liquid-glass">
      <p class="eyebrow">FIELD NOTE</p>
      <h1>{post.data.title}</h1>
      <p class="post-description">{post.data.description}</p>

      <div class="meta">
        <time datetime={date.toISOString()} class="publish-time">
          <CalendarDays size={15} stroke-width={1.8} aria-hidden="true" />
          <span class="local-time">{fallbackDate}</span>
        </time>
        {updatedDate && (
          <span class="updated" data-updated={updatedDate.toISOString()}>
            <RefreshCw size={14} stroke-width={1.8} aria-hidden="true" />
            <span class="relative-time">近期</span>更新
          </span>
        )}
        <span class="reading-time">
          <Clock3 size={15} stroke-width={1.8} aria-hidden="true" />
          阅读约 {readingTime} 分钟
        </span>
      </div>

      {post.data.tags && (
        <div class="tags" aria-label="文章标签">
          {post.data.tags.map((tag: string) => (
            <a href={`/tags/${encodeURIComponent(tag)}`} class="tag">{tag}</a>
          ))}
        </div>
      )}
    </header>

    {post.data.cover && (
      <figure class="cover">
        <img src={post.data.cover.url} alt={coverAlt} loading="eager" />
        <figcaption>{coverAlt}</figcaption>
      </figure>
    )}

    <div class="content" id="article-content">
      <Content />
    </div>
    <ImageLightbox />

    <footer class="post-footer">
      <a href="/blog">
        <ArrowLeft size={16} stroke-width={1.8} aria-hidden="true" />
        返回文章列表
      </a>
    </footer>

    <section
      class="comments liquid-glass"
      aria-labelledby="comments-title"
      data-discussion-term={`blog/${post.slug}`}
    >
      <div class="comments-heading">
        <p class="eyebrow">DISCUSSION</p>
        <h2 id="comments-title">评论</h2>
      </div>
      <p class="comments-status" role="status" aria-live="polite">正在加载评论…</p>
      <div class="comments-list"></div>
      <div class="comments-fallback" hidden>
        <p class="comments-fallback-message">评论暂时无法加载，但仍可在 GitHub Discussions 中查看和回复。</p>
        <div class="comments-fallback-actions">
          <a
            class="comments-discussions-link"
            href="https://github.com/fine405/blog/discussions"
            target="_blank"
            rel="noreferrer"
          >
            前往 GitHub 评论
          </a>
          <button class="comments-retry" type="button">重新加载</button>
        </div>
      </div>
    </section>
  </article>

  <script is:inline>
    (function() {
      function formatRelativeTime(date) {
        const now = new Date();
        const diff = now.getTime() - date.getTime();
        const minutes = Math.floor(diff / 60000);
        const hours = Math.floor(diff / 3600000);
        const days = Math.floor(diff / 86400000);

        if (minutes < 1) return '刚刚';
        if (minutes < 60) return minutes + ' 分钟前';
        if (hours < 24) return hours + ' 小时前';
        if (days < 30) return days + ' 天前';
        if (days < 365) return Math.floor(days / 30) + ' 个月前';
        return Math.floor(days / 365) + ' 年前';
      }

      function formatLocalTime(date) {
        return date.toLocaleDateString('zh-CN', {
          year: 'numeric',
          month: '2-digit',
          day: '2-digit',
        });
      }

      function updateTimes() {
        var timeEl = document.querySelector('.publish-time');
        if (timeEl) {
          var dateStr = timeEl.getAttribute('datetime');
          var localTimeEl = timeEl.querySelector('.local-time');
          if (dateStr && localTimeEl) localTimeEl.textContent = formatLocalTime(new Date(dateStr));
        }

        var updatedEl = document.querySelector('.updated[data-updated]');
        if (updatedEl) {
          var updateDateStr = updatedEl.getAttribute('data-updated');
          if (updateDateStr) {
            var updateDate = new Date(updateDateStr);
            updatedEl.setAttribute('title', '更新于 ' + formatLocalTime(updateDate));
            var relativeTimeEl = updatedEl.querySelector('.relative-time');
            if (relativeTimeEl) relativeTimeEl.textContent = formatRelativeTime(updateDate);
          }
        }
      }

      function setupReadingProgress() {
        const content = document.getElementById('article-content');
        const progress = document.getElementById('reading-progress-bar');

        if (window['__articleProgressHandler']) {
          window.removeEventListener('scroll', window['__articleProgressHandler']);
          window.removeEventListener('resize', window['__articleProgressHandler']);
          window['__articleProgressHandler'] = undefined;
        }
        if (!content || !progress) return;

        const updateProgress = () => {
          const start = content.getBoundingClientRect().top + window.scrollY;
          const end = start + content.offsetHeight - window.innerHeight;
          const percent = end <= start ? 1 : Math.min(1, Math.max(0, (window.scrollY - start) / (end - start)));
          progress.style.transform = 'scaleX(' + percent + ')';
        };

        window['__articleProgressHandler'] = updateProgress;
        window.addEventListener('scroll', updateProgress, { passive: true });
        window.addEventListener('resize', updateProgress, { passive: true });
        updateProgress();
      }

      function setupArticleToc() {
        if (window['__articleTocController']) {
          window['__articleTocController'].abort();
          window['__articleTocController'] = undefined;
        }

        const toc = document.querySelector('[data-article-toc]');
        const content = document.getElementById('article-content');
        if (!toc || !content) return;

        const links = Array.from(toc.querySelectorAll('[data-toc-link]'));
        const sections = links
          .map((link) => ({
            link,
            section: document.getElementById(link.dataset.headingId || ''),
          }))
          .filter((item) => item.section);
        if (!sections.length) return;

        const controller = new AbortController();
        const { signal } = controller;
        const toggle = toc.querySelector('.toc-toggle');
        const panel = toc.querySelector('.toc-panel');
        const nav = toc.querySelector('.toc-nav');
        const progressFill = toc.querySelector('[data-toc-progress-fill]');
        const progressLabels = toc.querySelectorAll('[data-toc-progress-text]');
        const compactQuery = window.matchMedia('(max-width: 1279px)');
        const reduceMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
        let activeId = '';
        let frame = 0;
        let navigationTargetId = '';
        let navigationReleaseTimer = 0;

        window['__articleTocController'] = controller;

        const syncPanelAccessibility = () => {
          const isCompact = compactQuery.matches;
          const isOpen = toc.classList.contains('is-open');
          toggle?.setAttribute('aria-expanded', String(isCompact && isOpen));

          if (!panel) return;
          if (isCompact && !isOpen) {
            panel.setAttribute('aria-hidden', 'true');
            panel.setAttribute('inert', '');
          } else {
            panel.removeAttribute('aria-hidden');
            panel.removeAttribute('inert');
          }
        };

        const setOpen = (open) => {
          const shouldOpen = compactQuery.matches && open && toc.classList.contains('is-visible');
          toc.classList.toggle('is-open', shouldOpen);
          syncPanelAccessibility();
        };

        const centerActiveLink = (link) => {
          if (!nav || nav.scrollHeight <= nav.clientHeight) return;
          const navRect = nav.getBoundingClientRect();
          const linkRect = link.getBoundingClientRect();
          const edgePadding = 8;
          if (linkRect.top < navRect.top + edgePadding) {
            nav.scrollTop -= navRect.top + edgePadding - linkRect.top;
          } else if (linkRect.bottom > navRect.bottom - edgePadding) {
            nav.scrollTop += linkRect.bottom - (navRect.bottom - edgePadding);
          }
        };

        const setActive = (id) => {
          if (!id || id === activeId) return;
          activeId = id;

          sections.forEach(({ link }) => {
            const isActive = link.dataset.headingId === id;
            link.classList.toggle('is-active', isActive);
            if (isActive) {
              link.setAttribute('aria-current', 'location');
              centerActiveLink(link);
            } else {
              link.removeAttribute('aria-current');
            }
          });
        };

        const updateToc = () => {
          frame = 0;
          const contentRect = content.getBoundingClientRect();
          const revealLine = Math.min(window.innerHeight * 0.3, 240);
          const exitLine = Math.min(window.innerHeight * 0.24, 200);
          const isVisible = contentRect.top <= revealLine && contentRect.bottom > exitLine;
          toc.classList.toggle('is-visible', isVisible);
          if (!isVisible && toc.classList.contains('is-open')) setOpen(false);

          const contentTop = contentRect.top + window.scrollY;
          const contentEnd = contentTop + content.offsetHeight - window.innerHeight;
          const progress = contentEnd <= contentTop
            ? (contentRect.top <= 0 ? 1 : 0)
            : Math.min(1, Math.max(0, (window.scrollY - contentTop) / (contentEnd - contentTop)));
          const progressText = Math.round(progress * 100) + '%';
          if (progressFill) progressFill.style.transform = 'scaleX(' + progress + ')';
          progressLabels.forEach((label) => { label.textContent = progressText; });

          if (navigationTargetId) {
            setActive(navigationTargetId);
            return;
          }

          const activationLine = Math.min(window.innerHeight * 0.28, 220);
          let current = sections[0];
          sections.forEach((item) => {
            if (item.section.getBoundingClientRect().top <= activationLine) current = item;
          });
          setActive(current.link.dataset.headingId || '');
        };

        const scheduleUpdate = () => {
          if (!frame) frame = window.requestAnimationFrame(updateToc);
        };

        const scheduleNavigationRelease = () => {
          if (!navigationTargetId) return;
          window.clearTimeout(navigationReleaseTimer);
          navigationReleaseTimer = window.setTimeout(() => {
            navigationTargetId = '';
            updateToc();
          }, 140);
        };

        const handleScroll = () => {
          scheduleUpdate();
          scheduleNavigationRelease();
        };

        links.forEach((link) => {
          link.addEventListener('click', (event) => {
            const id = link.dataset.headingId || '';
            const target = document.getElementById(id);
            if (!target) return;

            event.preventDefault();
            navigationTargetId = id;
            setActive(id);
            setOpen(false);

            const url = new URL(window.location.href);
            url.hash = id;
            if (window.location.hash !== url.hash) window.history.pushState({}, '', url);
            target.scrollIntoView({
              behavior: reduceMotionQuery.matches ? 'auto' : 'smooth',
              block: 'start',
            });
            scheduleNavigationRelease();
          }, { signal });
        });

        toggle?.addEventListener('click', () => {
          setOpen(!toc.classList.contains('is-open'));
        }, { signal });

        document.addEventListener('pointerdown', (event) => {
          if (!compactQuery.matches || !toc.classList.contains('is-open')) return;
          if (event.target instanceof Node && !toc.contains(event.target)) setOpen(false);
        }, { signal });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') setOpen(false);
        }, { signal });

        const handleModeChange = () => {
          setOpen(false);
          syncPanelAccessibility();
          scheduleUpdate();
        };
        compactQuery.addEventListener('change', handleModeChange);
        signal.addEventListener('abort', () => {
          compactQuery.removeEventListener('change', handleModeChange);
          if (frame) window.cancelAnimationFrame(frame);
          window.clearTimeout(navigationReleaseTimer);
        }, { once: true });

        window.addEventListener('scroll', handleScroll, { passive: true, signal });
        window.addEventListener('resize', scheduleUpdate, { passive: true, signal });
        syncPanelAccessibility();
        updateToc();
      }

      function setupCodeBlocks() {
        document.querySelectorAll('.content pre').forEach((pre) => {
          if (pre.dataset.enhanced === 'true') return;
          pre.dataset.enhanced = 'true';
          pre.classList.add('code-frame');

          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'copy-code-button';
          button.textContent = '复制';
          button.setAttribute('aria-label', '复制代码');
          button.addEventListener('click', async () => {
            const code = pre.querySelector('code');
            if (!code) return;

            button.textContent = '已复制';
            button.classList.add('copied');
            window.setTimeout(() => {
              button.textContent = '复制';
              button.classList.remove('copied');
            }, 1600);

            try {
              await navigator.clipboard.writeText(code.textContent || '');
            } catch {
              button.textContent = '复制失败';
              button.classList.remove('copied');
            }
          });
          pre.appendChild(button);
        });
      }

      function initArticle() {
        updateTimes();
        setupReadingProgress();
        setupArticleToc();
        setupCodeBlocks();
      }

      initArticle();
      if (window['__postArticleInitHandler']) {
        document.removeEventListener('astro:page-load', window['__postArticleInitHandler']);
      }
      window['__postArticleInitHandler'] = initArticle;
      document.addEventListener('astro:page-load', window['__postArticleInitHandler']);
    })();
  </script>

  <script is:inline>
    (function() {
      const COMMENTS_API = 'https://fine405.vercel.app/api/discussions';
      const ASSOCIATION_LABELS = {
        OWNER: '作者',
        MEMBER: '成员',
        COLLABORATOR: '协作者',
        CONTRIBUTOR: '贡献者',
        FIRST_TIMER: '首次参与',
        FIRST_TIME_CONTRIBUTOR: '首次贡献',
        APP: '应用',
      };

      function getDiscussionTerm() {
        const comments = document.querySelector('.comments[data-discussion-term]');
        return comments?.dataset.discussionTerm || '';
      }

      function getDiscussionSearchUrl(term) {
        return 'https://github.com/fine405/blog/discussions?discussions_q=' + encodeURIComponent(term);
      }

      function getSafeGitHubUrl(value, fallback) {
        try {
          const url = new URL(value);
          return url.protocol === 'https:' && url.hostname === 'github.com' ? url.href : fallback;
        } catch {
          return fallback;
        }
      }

      function getCommentText(bodyHTML) {
        const template = document.createElement('template');
        template.innerHTML = bodyHTML || '';
        template.content.querySelectorAll('script, style, noscript').forEach((element) => element.remove());
        template.content.querySelectorAll('br').forEach((element) => element.replaceWith('\n'));
        template.content.querySelectorAll('p, div, li, pre, blockquote').forEach((element) => {
          element.appendChild(document.createTextNode('\n'));
        });
        return (template.content.textContent || '').replace(/\n{3,}/g, '\n\n').trim();
      }

      function formatCommentDate(value) {
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return '';
        return new Intl.DateTimeFormat('zh-CN', {
          year: 'numeric',
          month: '2-digit',
          day: '2-digit',
          hour: '2-digit',
          minute: '2-digit',
        }).format(date);
      }

      function createCommentCard(comment, isReply) {
        const card = document.createElement(isReply ? 'div' : 'article');
        card.className = isReply ? 'comment-card comment-reply' : 'comment-card';

        const header = document.createElement('div');
        header.className = 'comment-card-header';

        const fallbackUrl = 'https://github.com/fine405/blog/discussions';
        const author = document.createElement('a');
        author.className = 'comment-author';
        author.href = getSafeGitHubUrl(comment.author?.url, fallbackUrl);
        author.target = '_blank';
        author.rel = 'nofollow noreferrer';
        author.textContent = '@' + (comment.author?.login || 'github-user');
        header.appendChild(author);

        if (comment.authorAssociation && comment.authorAssociation !== 'NONE') {
          const association = document.createElement('span');
          association.className = 'comment-association';
          association.textContent = ASSOCIATION_LABELS[comment.authorAssociation] || comment.authorAssociation;
          header.appendChild(association);
        }

        const commentUrl = getSafeGitHubUrl(comment.url, fallbackUrl);
        const timeLink = document.createElement('a');
        timeLink.className = 'comment-date';
        timeLink.href = commentUrl;
        timeLink.target = '_blank';
        timeLink.rel = 'nofollow noreferrer';

        const time = document.createElement('time');
        time.dateTime = comment.createdAt || '';
        time.textContent = formatCommentDate(comment.createdAt);
        timeLink.appendChild(time);
        header.appendChild(timeLink);
        card.appendChild(header);

        const body = document.createElement('div');
        body.className = 'comment-card-body';
        body.textContent = comment.deletedAt
          ? '此评论已删除。'
          : comment.isMinimized
            ? '此评论已被折叠，请前往 GitHub 查看。'
            : getCommentText(comment.bodyHTML) || '（空评论）';
        card.appendChild(body);

        const footer = document.createElement('div');
        footer.className = 'comment-card-footer';

        if (!isReply && comment.replyCount > 0) {
          const replyCount = document.createElement('span');
          replyCount.textContent = comment.replyCount + ' 条回复';
          footer.appendChild(replyCount);
        }

        const replyLink = document.createElement('a');
        replyLink.href = commentUrl;
        replyLink.target = '_blank';
        replyLink.rel = 'nofollow noreferrer';
        replyLink.textContent = isReply ? '在 GitHub 查看' : '在 GitHub 回复';
        footer.appendChild(replyLink);
        card.appendChild(footer);

        if (!isReply && Array.isArray(comment.replies) && comment.replies.length > 0) {
          const replies = document.createElement('div');
          replies.className = 'comment-replies';
          comment.replies.slice(-5).forEach((reply) => {
            replies.appendChild(createCommentCard(reply, true));
          });
          card.appendChild(replies);
        }

        return card;
      }

      function renderDiscussion(data, elements, searchUrl) {
        const discussion = data?.discussion;
        if (!discussion || !Array.isArray(discussion.comments)) {
          throw new Error('Invalid comments response');
        }

        const discussionUrl = getSafeGitHubUrl(discussion.url, searchUrl);
        elements.link.href = discussionUrl;
        elements.link.textContent = '在 GitHub 参与讨论';
        elements.list.replaceChildren();

        const summary = document.createElement('div');
        summary.className = 'comments-summary';

        const count = document.createElement('span');
        count.textContent = Number(discussion.totalCommentCount || 0) + ' 条评论';
        summary.appendChild(count);

        const action = document.createElement('a');
        action.href = discussionUrl;
        action.target = '_blank';
        action.rel = 'noreferrer';
        action.textContent = '在 GitHub 回复';
        summary.appendChild(action);
        elements.list.appendChild(summary);

        if (discussion.comments.length === 0) {
          const empty = document.createElement('p');
          empty.className = 'comments-empty';
          empty.textContent = '还没有评论，欢迎留下第一条讨论。';
          elements.list.appendChild(empty);
        } else {
          const thread = document.createElement('div');
          thread.className = 'comment-thread';
          discussion.comments.forEach((comment) => {
            thread.appendChild(createCommentCard(comment, false));
          });
          elements.list.appendChild(thread);
        }

        elements.status.hidden = true;
        elements.fallback.hidden = true;
        elements.list.hidden = false;
      }

      function showCommentsFallback(elements, message, linkLabel) {
        elements.status.hidden = true;
        elements.list.hidden = true;
        elements.fallbackMessage.textContent = message;
        elements.link.textContent = linkLabel;
        elements.fallback.hidden = false;
      }

      async function loadComments() {
        setupCommentsRetry();

        const status = document.querySelector('.comments-status');
        const list = document.querySelector('.comments-list');
        const fallback = document.querySelector('.comments-fallback');
        const fallbackMessage = document.querySelector('.comments-fallback-message');
        const discussionsLink = document.querySelector('.comments-discussions-link');
        if (!status || !list || !fallback || !fallbackMessage || !discussionsLink) return;

        if (window['__commentsRequestController']) {
          window['__commentsRequestController'].abort();
        }

        const controller = new AbortController();
        window['__commentsRequestController'] = controller;
        const elements = {
          status,
          list,
          fallback,
          fallbackMessage,
          link: discussionsLink,
        };

        status.hidden = false;
        status.textContent = '正在加载评论…';
        list.hidden = false;
        list.replaceChildren();
        fallback.hidden = true;

        const term = getDiscussionTerm();
        const searchUrl = getDiscussionSearchUrl(term);
        discussionsLink.href = searchUrl;
        discussionsLink.textContent = '前往 GitHub 评论';

        const params = new URLSearchParams({ term });
        const timeout = window.setTimeout(() => controller.abort(), 10000);

        try {
          const response = await fetch(COMMENTS_API + '?' + params, {
            cache: 'no-store',
            headers: { Accept: 'application/json' },
            signal: controller.signal,
          });
          if (window['__commentsRequestController'] !== controller) return;

          if (response.status === 404) {
            discussionsLink.href = 'https://github.com/fine405/blog/discussions/new?category=general';
            showCommentsFallback(
              elements,
              '还没有评论，欢迎在 GitHub 发起第一条讨论。',
              '发起 GitHub 讨论'
            );
            return;
          }
          if (!response.ok) throw new Error('Comments request failed: ' + response.status);

          renderDiscussion(await response.json(), elements, searchUrl);
        } catch (error) {
          if (window['__commentsRequestController'] !== controller) return;
          const timedOut = error?.name === 'AbortError';
          showCommentsFallback(
            elements,
            timedOut
              ? '评论加载超时，但仍可在 GitHub Discussions 中查看和回复。'
              : '评论暂时无法加载，但仍可在 GitHub Discussions 中查看和回复。',
