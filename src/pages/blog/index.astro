---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getBlogDates } from '../../utils/git-dates';

const rawPosts = await getCollection('blog', ({ data }) => {
  // 开发环境显示所有文章，生产环境隐藏草稿
  return import.meta.env.DEV || !data.draft;
});

// 为每篇文章计算 Git 时间
const posts = rawPosts.map((post) => {
  const { date, updatedDate } = getBlogDates(
    post.slug,
    post.data.date,
    post.data.updatedDate,
    post.data.disableUpdateDate
  );
  return { ...post, date, updatedDate };
}).sort((a, b) => {
  // 置顶文章优先，数字越大越靠前
  const aPinned = a.data.pinned ?? 0;
  const bPinned = b.data.pinned ?? 0;
  if (aPinned !== bPinned) return bPinned - aPinned;
  // 默认按发布时间排序
  const aTime = a.date.valueOf();
  const bTime = b.date.valueOf();
  if (bTime !== aTime) return bTime - aTime;
  // 日期相同时按标题字母顺序
  return a.data.title.localeCompare(b.data.title, 'zh-CN');
});
---

<BaseLayout
  title="文章列表 - Fine"
  description="按发布时间与更新时间浏览全部技术文章，覆盖 AI、TypeScript、系统设计与开发工具实践。"
  tags={['技术文章', 'AI', 'TypeScript', '系统设计', '开发工具']}
  schemaType="CollectionPage"
  schemaTitle="Fine 技术文章列表"
>
  <div class="page-header">
    <h1>所有文章</h1>
    <div class="sort-toggle" role="group" aria-label="排序方式">
      <button class="sort-btn" data-sort="updated">最近更新</button>
      <button class="sort-btn active" data-sort="published">发布时间</button>
    </div>
  </div>
  <ul class="post-list" id="post-list">
    {posts.map((post) => (
      <li 
        data-pinned={post.data.pinned ?? 0}
        data-published={post.date.valueOf()}
        data-updated={(post.updatedDate ?? post.date).valueOf()}
        data-title={post.data.title}
      >
        <a href={`/blog/${post.slug}`} class:list={[{ pinned: post.data.pinned }]}>
          <article>
            <h2>
              {post.data.pinned && <span class="pin-icon">📌</span>}
              {post.data.title}
            </h2>
            <p class="meta">
              <time datetime={post.date.toISOString()} class="publish-time">
                发布于 <span class="local-time"></span>
              </time>
              {post.updatedDate && (
                <span class="updated" data-updated={post.updatedDate.toISOString()}>
                  · <span class="relative-time"></span>更新
                </span>
              )}
            </p>
            <p class="excerpt">{post.data.description}</p>
          </article>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  h1 {
    font-size: 1.75rem;
    margin: 0;
  }

  .sort-toggle {
    display: flex;
    gap: 0.25rem;
    background: var(--bg-secondary);
    padding: 0.25rem;
    border-radius: 6px;
  }

  .sort-btn {
    padding: 0.4rem 0.75rem;
    border: none;
    background: transparent;
    color: var(--text-secondary);
    font-size: 0.85rem;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .sort-btn:hover {
    color: var(--text);
  }

  .sort-btn.active {
    background: var(--bg);
    color: var(--text);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
  }

  .post-list {
    list-style: none;
  }

  .post-list li {
    margin-bottom: 1rem;
  }

  .post-list a {
    text-decoration: none;
    color: inherit;
    display: block;
    padding: 1.25rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: border-color 0.2s, background 0.2s;
  }

  .post-list a:hover {
    border-color: var(--accent);
    background: var(--bg-secondary);
  }

  .post-list a.pinned {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 5%, transparent);
  }

  .pin-icon {
    margin-right: 0.25rem;
  }

  .post-list h2 {
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .meta {
    font-size: 0.85rem;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .updated {
    color: var(--accent);
    cursor: help;
  }

  .excerpt {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.5;
  }
</style>

<script is:inline>
  (function() {
    var SORT_KEY = 'blog-sort-preference';

    function formatRelativeTime(date) {
      var now = new Date();
      var diff = now.getTime() - date.getTime();
      var minutes = Math.floor(diff / 60000);
      var hours = Math.floor(diff / 3600000);
      var days = Math.floor(diff / 86400000);
      
      if (minutes < 1) return '刚刚';
      if (minutes < 60) return minutes + ' 分钟前';
      if (hours < 24) return hours + ' 小时前';
      if (days < 30) return days + ' 天前';
      if (days < 365) return Math.floor(days / 30) + ' 个月前';
      return Math.floor(days / 365) + ' 年前';
    }

    function formatLocalTime(date) {
      return date.toLocaleString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' });
    }

    function updateTimes() {
      document.querySelectorAll('.publish-time').forEach(function(el) {
        var dateStr = el.getAttribute('datetime');
        var localTimeEl = el.querySelector('.local-time');
        if (dateStr && localTimeEl) {
          localTimeEl.textContent = formatLocalTime(new Date(dateStr));
        }
      });
      document.querySelectorAll('.updated[data-updated]').forEach(function(el) {
        var dateStr = el.getAttribute('data-updated');
        if (dateStr) {
          var date = new Date(dateStr);
          el.setAttribute('title', formatLocalTime(date));
          var relativeTimeEl = el.querySelector('.relative-time');
          if (relativeTimeEl) {
            relativeTimeEl.textContent = formatRelativeTime(date);
          }
        }
      });
    }

    function sortPosts(sortBy) {
      var list = document.getElementById('post-list');
      if (!list) return;
      var items = Array.from(list.children);
      
      items.sort(function(a, b) {
        var aPinned = parseInt(a.dataset.pinned) || 0;
        var bPinned = parseInt(b.dataset.pinned) || 0;
        if (aPinned !== bPinned) return bPinned - aPinned;
        
        var aTime = sortBy === 'published' 
          ? parseInt(a.dataset.published) 
          : parseInt(a.dataset.updated);
        var bTime = sortBy === 'published' 
          ? parseInt(b.dataset.published) 
          : parseInt(b.dataset.updated);
        if (bTime !== aTime) return bTime - aTime;
        
        return (a.dataset.title || '').localeCompare(b.dataset.title || '', 'zh-CN');
      });
      
      items.forEach(function(item) { list.appendChild(item); });
    }

    function initSortToggle() {
      var savedSort = localStorage.getItem(SORT_KEY) || 'published';
      var buttons = document.querySelectorAll('.sort-btn');
      
      buttons.forEach(function(btn) {
        btn.classList.toggle('active', btn.dataset.sort === savedSort);
      });

      buttons.forEach(function(btn) {
        if (btn.dataset.bound === 'true') return;
        btn.dataset.bound = 'true';
        btn.addEventListener('click', function() {
          var sortBy = this.dataset.sort;
          buttons.forEach(function(b) { b.classList.remove('active'); });
          this.classList.add('active');
          localStorage.setItem(SORT_KEY, sortBy);
          sortPosts(sortBy);
        });
      });
      
      sortPosts(savedSort);
    }

    function init() {
      updateTimes();
      initSortToggle();
    }

    init();
    if (window['__blogIndexInitHandler']) {
      document.removeEventListener('astro:page-load', window['__blogIndexInitHandler']);
    }
    window['__blogIndexInitHandler'] = init;
    document.addEventListener('astro:page-load', window['__blogIndexInitHandler']);
  })();
</script>
