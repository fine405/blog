---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { ArrowUpRight, Clock3, FileText } from '@lucide/astro';
import { getBlogDates } from '../../utils/git-dates';

const rawPosts = await getCollection('blog', ({ data }) => {
  return import.meta.env.DEV || !data.draft;
});

const posts = rawPosts.map((post) => {
  const { date, updatedDate } = getBlogDates(
    post.slug,
    post.data.date,
    post.data.updatedDate,
    post.data.disableUpdateDate
  );
  return { ...post, date, updatedDate };
}).sort((a, b) => {
  const aTime = a.date.valueOf();
  const bTime = b.date.valueOf();
  if (bTime !== aTime) return bTime - aTime;
  return a.data.title.localeCompare(b.data.title, 'zh-CN');
});
---

<BaseLayout
  title="文章列表 - Fine"
  description="按发布时间与更新时间浏览全部技术文章，覆盖 AI、TypeScript、系统设计与开发工具实践。"
  tags={['技术文章', 'AI', 'TypeScript', '系统设计', '开发工具']}
  schemaType="CollectionPage"
  schemaTitle="Fine 技术文章列表"
>
  <header class="page-hero">
    <div>
      <p class="eyebrow">WRITING ARCHIVE</p>
      <h1>所有文章</h1>
      <p class="page-description">关于 AI 工程、软件架构与开发效率的长期记录。</p>
    </div>
    <div class="article-count liquid-glass" aria-label={`共 ${posts.length} 篇文章`}>
      <FileText size={20} stroke-width={1.7} aria-hidden="true" />
      <span><strong>{posts.length}</strong> 篇文章</span>
    </div>
  </header>

  <ol class="post-list">
    {posts.map((post, index) => (
      <li data-reveal style={`--reveal-delay: ${Math.min(index * 45, 180)}ms`}>
        <a href={`/blog/${post.slug}`} class="liquid-glass">
          <span class="post-index" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
          <article>
            <div class="meta">
              <time datetime={post.date.toISOString()} class="publish-time">
                <Clock3 size={14} stroke-width={1.8} aria-hidden="true" />
                <span class="local-time">{post.date.toLocaleDateString('zh-CN')}</span>
              </time>
              {post.updatedDate && (
                <span class="updated" data-updated={post.updatedDate.toISOString()}>
                  <span class="relative-time">近期</span>更新
                </span>
              )}
            </div>
            <h2>{post.data.title}</h2>
            <p class="excerpt">{post.data.description}</p>
            {post.data.tags && (
              <div class="tags" aria-label="文章标签">
                {post.data.tags.slice(0, 3).map((tag) => <span>{tag}</span>)}
              </div>
            )}
          </article>
          <span class="post-arrow" aria-hidden="true">
            <ArrowUpRight size={20} stroke-width={1.8} />
          </span>
        </a>
      </li>
    ))}
  </ol>
</BaseLayout>

<style>
  .page-hero {
    padding: 2.75rem 0 4.5rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 3rem;
    border-bottom: 1px solid var(--border);
  }

  .eyebrow {
    color: var(--accent-strong);
    font-size: 0.7rem;
    font-weight: 720;
    letter-spacing: 0.18em;
  }

  h1 {
    margin-top: 0.85rem;
    color: var(--text-primary);
    font-size: clamp(3rem, 6.3vw, 5.4rem);
    font-weight: 710;
    letter-spacing: -0.065em;
    line-height: 1.05;
  }

  .page-description {
    max-width: 570px;
    margin-top: 1.2rem;
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.75;
  }

  .article-count {
    flex: 0 0 auto;
    padding: 0.85rem 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    overflow: hidden;
    border: 1px solid var(--glass-stroke-muted);
    border-radius: 16px;
    background: var(--glass-fill);
    color: var(--text-secondary);
    font-size: 0.82rem;
  }

  .article-count strong {
    color: var(--text-primary);
    font-size: 1.05rem;
    font-weight: 700;
  }

  .post-list {
    margin-top: 2rem;
    list-style: none;
  }

  .post-list li + li {
    margin-top: 0.8rem;
  }

  .post-list a {
    position: relative;
    padding: clamp(1.35rem, 2.6vw, 2rem);
    display: grid;
    grid-template-columns: 54px minmax(0, 1fr) 42px;
    align-items: start;
    gap: 1.2rem;
    overflow: hidden;
    border: 1px solid var(--glass-stroke-muted);
    border-radius: var(--radius-md);
    background: var(--glass-fill);
    color: inherit;
    text-decoration: none;
    transition:
      transform 240ms var(--ease-out),
      border-color 200ms ease,
      background-color 200ms ease,
      box-shadow 240ms ease;
  }

  .post-list a::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    z-index: 4;
    background: var(--accent);
    opacity: 0;
    transform: scaleY(0.4);
    transition: opacity 200ms ease, transform 240ms var(--ease-out);
  }

  .post-list a:hover {
    border-color: var(--glass-stroke);
    background: var(--glass-fill-strong);
    box-shadow:
      var(--glass-shadow-hover),
      inset 0 1px 0 var(--glass-highlight);
    transform: translateY(-3px);
  }

  .post-list a:hover::before {
    opacity: 1;
    transform: scaleY(1);
  }

  .post-index {
    padding-top: 0.15rem;
    color: var(--text-tertiary);
    font-size: 0.7rem;
    font-weight: 680;
    letter-spacing: 0.08em;
  }

  .meta {
    margin-bottom: 0.7rem;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.55rem 0.9rem;
    color: var(--text-tertiary);
    font-size: 0.74rem;
  }

  .publish-time {
    display: inline-flex;
    align-items: center;
    gap: 0.38rem;
  }

  .updated {
    padding: 0.22rem 0.48rem;
    border-radius: 6px;
    background: var(--accent-soft);
    color: var(--accent-strong);
    cursor: help;
    font-weight: 620;
  }

  .post-list h2 {
    color: var(--text-primary);
    font-size: clamp(1.15rem, 2.2vw, 1.48rem);
    font-weight: 650;
    letter-spacing: -0.03em;
    line-height: 1.45;
    transition: color 180ms ease;
  }

  .post-list a:hover h2 {
    color: var(--accent-strong);
  }

  .excerpt {
    max-width: 860px;
    margin-top: 0.65rem;
    color: var(--text-secondary);
    font-size: 0.88rem;
    line-height: 1.75;
  }

  .tags {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .tags span {
    padding: 0.3rem 0.58rem;
    border: 1px solid var(--border);
    border-radius: 7px;
    color: var(--text-tertiary);
    font-size: 0.68rem;
    font-weight: 570;
  }

  .post-arrow {
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border);
    border-radius: 12px;
    color: var(--text-tertiary);
    transition:
      color 180ms ease,
      background-color 180ms ease,
      border-color 180ms ease,
      transform 220ms var(--ease-out);
  }

  .post-list a:hover .post-arrow {
    border-color: transparent;
    background: var(--accent-soft);
    color: var(--accent-strong);
    transform: translate(2px, -2px) rotate(4deg);
  }

  @media (max-width: 720px) {
    .page-hero {
      padding: 1.5rem 0 3rem;
      align-items: flex-start;
      flex-direction: column;
      gap: 1.5rem;
    }

    h1 {
      font-size: clamp(3rem, 16vw, 4.5rem);
    }

    .post-list {
      margin-top: 1rem;
    }

    .post-list a {
      padding: 1.25rem;
      grid-template-columns: minmax(0, 1fr) 38px;
      gap: 0.75rem;
    }

    .post-index {
      display: none;
    }

    .excerpt {
      display: -webkit-box;
      overflow: hidden;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 3;
    }

    .post-arrow {
      width: 36px;
      height: 36px;
    }
  }
</style>

<script is:inline>
  (function() {
    function formatRelativeTime(date) {
      var now = new Date();
      var diff = now.getTime() - date.getTime();
      var minutes = Math.floor(diff / 60000);
      var hours = Math.floor(diff / 3600000);
      var days = Math.floor(diff / 86400000);

      if (minutes < 1) return '刚刚';
      if (minutes < 60) return minutes + ' 分钟前';
      if (hours < 24) return hours + ' 小时前';
      if (days < 30) return days + ' 天前';
      if (days < 365) return Math.floor(days / 30) + ' 个月前';
      return Math.floor(days / 365) + ' 年前';
    }

    function formatLocalTime(date) {
      return date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' });
    }

    function updateTimes() {
      document.querySelectorAll('.publish-time').forEach(function(el) {
        var dateStr = el.getAttribute('datetime');
        var localTimeEl = el.querySelector('.local-time');
        if (dateStr && localTimeEl) localTimeEl.textContent = formatLocalTime(new Date(dateStr));
      });

      document.querySelectorAll('.updated[data-updated]').forEach(function(el) {
        var dateStr = el.getAttribute('data-updated');
        if (!dateStr) return;
        var date = new Date(dateStr);
        el.setAttribute('title', '更新于 ' + formatLocalTime(date));
        var relativeTimeEl = el.querySelector('.relative-time');
        if (relativeTimeEl) relativeTimeEl.textContent = formatRelativeTime(date);
      });
    }

    updateTimes();
    if (window['__blogIndexInitHandler']) {
      document.removeEventListener('astro:page-load', window['__blogIndexInitHandler']);
    }
    window['__blogIndexInitHandler'] = updateTimes;
    document.addEventListener('astro:page-load', window['__blogIndexInitHandler']);
  })();
</script>
