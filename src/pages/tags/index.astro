---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { ArrowUpRight, Hash } from '@lucide/astro';

const posts = await getCollection('blog', ({ data }) => {
  return import.meta.env.DEV || !data.draft;
});

const tags = [...new Set(posts.flatMap((post) => post.data.tags || []))]
  .map((tag) => ({
    name: tag,
    count: posts.filter((post) => post.data.tags?.includes(tag)).length,
  }))
  .sort((a, b) => b.count - a.count || a.name.localeCompare(b.name, 'zh-CN'));
---

<BaseLayout
  title="标签 - Fine"
  description="按主题浏览博客内容，快速定位 AI、TypeScript、系统设计与开发工具相关文章。"
  tags={['标签页', 'AI', 'TypeScript', '开发工具']}
  schemaType="CollectionPage"
  schemaTitle="Fine 文章标签列表"
>
  <header class="page-hero">
    <p class="eyebrow">EXPLORE BY TOPIC</p>
    <h1>内容主题</h1>
    <p>从一个关键词出发，沿着主题脉络找到相关实践与思考。</p>
  </header>

  <ul class="tag-list">
    {tags.map((tag, index) => (
      <li data-reveal style={`--reveal-delay: ${Math.min(index * 40, 160)}ms`}>
        <a href={`/tags/${encodeURIComponent(tag.name)}`} class="liquid-glass">
          <span class="tag-icon" aria-hidden="true">
            <Hash size={19} stroke-width={1.8} />
          </span>
          <span class="tag-copy">
            <strong>{tag.name}</strong>
            <small>{tag.count} 篇文章</small>
          </span>
          <span class="tag-arrow" aria-hidden="true">
            <ArrowUpRight size={18} stroke-width={1.8} />
          </span>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .page-hero {
    max-width: 760px;
    padding: 2.75rem 0 4.5rem;
  }

  .eyebrow {
    color: var(--accent-strong);
    font-size: 0.7rem;
    font-weight: 720;
    letter-spacing: 0.18em;
  }

  h1 {
    margin-top: 0.85rem;
    color: var(--text-primary);
    font-size: clamp(3rem, 6.3vw, 5.4rem);
    font-weight: 710;
    letter-spacing: -0.065em;
    line-height: 1.05;
  }

  .page-hero > p:last-child {
    max-width: 560px;
    margin-top: 1.25rem;
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.75;
  }

  .tag-list {
    padding-top: 2rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
    border-top: 1px solid var(--border);
    list-style: none;
  }

  .tag-list a {
    min-height: 116px;
    padding: 1.25rem;
    display: grid;
    grid-template-columns: 40px minmax(0, 1fr) 28px;
    align-items: center;
    gap: 0.9rem;
    overflow: hidden;
    border: 1px solid var(--glass-stroke-muted);
    border-radius: var(--radius-md);
    background: var(--glass-fill);
    color: inherit;
    text-decoration: none;
    transition:
      transform 220ms var(--ease-out),
      border-color 180ms ease,
      background-color 180ms ease,
      box-shadow 220ms ease;
  }

  .tag-list a:hover {
    border-color: var(--glass-stroke);
    background: var(--glass-fill-strong);
    box-shadow:
      var(--glass-shadow-hover),
      inset 0 1px 0 var(--glass-highlight);
    transform: translateY(-3px);
  }

  .tag-icon {
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--glass-stroke-muted);
    border-radius: 14px;
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.34), var(--accent-soft));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.38);
    color: var(--accent-strong);
    transition: transform 220ms var(--ease-out);
  }

  .tag-list a:hover .tag-icon {
    transform: rotate(-5deg) scale(1.04);
  }

  .tag-copy {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .tag-copy strong {
    overflow: hidden;
    color: var(--text-primary);
    font-size: 0.96rem;
    font-weight: 650;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .tag-copy small {
    color: var(--text-tertiary);
    font-size: 0.72rem;
  }

  .tag-arrow {
    color: var(--text-tertiary);
    transition: color 180ms ease, transform 220ms var(--ease-out);
  }

  .tag-list a:hover .tag-arrow {
    color: var(--accent-strong);
    transform: translate(2px, -2px);
  }

  @media (max-width: 920px) {
    .tag-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 600px) {
    .page-hero {
      padding: 1.5rem 0 3rem;
    }

    h1 {
      font-size: clamp(3rem, 16vw, 4.5rem);
    }

    .tag-list {
      padding-top: 1rem;
      grid-template-columns: 1fr;
    }

    .tag-list a {
      min-height: 96px;
    }
  }
</style>
