---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { ArrowLeft, ArrowUpRight, Clock3 } from '@lucide/astro';
import { getBlogDates } from '../../utils/git-dates';

export async function getStaticPaths() {
  const rawPosts = await getCollection('blog', ({ data }) => {
    return import.meta.env.DEV || !data.draft;
  });
  const tags = [...new Set(rawPosts.flatMap((post) => post.data.tags || []))];

  const posts = rawPosts.map((post) => {
    const { date, updatedDate } = getBlogDates(
      post.slug,
      post.data.date,
      post.data.updatedDate,
      post.data.disableUpdateDate
    );
    return { ...post, date, updatedDate };
  });

  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts.filter((post) => post.data.tags?.includes(tag))
        .sort((a, b) => b.date.valueOf() - a.date.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
const formatDate = (date: Date) => new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
}).format(date);
---

<BaseLayout
  title={`${tag} - Fine`}
  description={`收录 ${posts.length} 篇与 ${tag} 相关的技术文章，持续更新实践经验与方法总结。`}
  tags={[tag, '技术博客']}
  schemaType="CollectionPage"
  schemaTitle={`${tag} 相关文章`}
>
  <header class="page-hero">
    <a href="/tags" class="back-link">
      <ArrowLeft size={16} stroke-width={1.8} aria-hidden="true" />
      返回所有主题
    </a>
    <p class="eyebrow">TOPIC ARCHIVE</p>
    <h1><span aria-hidden="true">#</span>{tag}</h1>
    <p>共 {posts.length} 篇文章，按发布时间由近到远排列。</p>
  </header>

  <ol class="post-list">
    {posts.map((post, index) => (
      <li data-reveal style={`--reveal-delay: ${Math.min(index * 45, 180)}ms`}>
        <a href={`/blog/${post.slug}`} class="liquid-glass">
          <span class="post-index" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
          <article>
            <time datetime={post.date.toISOString()}>
              <Clock3 size={14} stroke-width={1.8} aria-hidden="true" />
              {formatDate(post.date)}
            </time>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
          </article>
          <span class="post-arrow" aria-hidden="true">
            <ArrowUpRight size={20} stroke-width={1.8} />
          </span>
        </a>
      </li>
    ))}
  </ol>
</BaseLayout>

<style>
  .page-hero {
    padding: 1.5rem 0 4.5rem;
    border-bottom: 1px solid var(--border);
  }

  .back-link {
    width: fit-content;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.58rem 0.82rem;
    border: 1px solid var(--glass-stroke-muted);
    border-radius: 999px;
    background: var(--surface-soft);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.2);
    color: var(--text-secondary);
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
    transition: color 180ms ease, transform 180ms var(--ease-out), background-color 180ms ease, border-color 180ms ease;
    -webkit-backdrop-filter: blur(14px) saturate(1.2);
    backdrop-filter: blur(14px) saturate(1.2);
  }

  .back-link:hover {
    border-color: var(--glass-stroke);
    background: var(--glass-fill-strong);
    color: var(--text-primary);
    transform: translateX(-3px);
  }

  .eyebrow {
    margin-top: 3.5rem;
    color: var(--accent-strong);
    font-size: 0.7rem;
    font-weight: 720;
    letter-spacing: 0.18em;
  }

  h1 {
    margin-top: 0.75rem;
    color: var(--text-primary);
    font-size: clamp(2.8rem, 6.3vw, 5.25rem);
    font-weight: 710;
    letter-spacing: -0.06em;
    line-height: 1.1;
  }

  h1 span {
    margin-right: 0.16em;
    color: var(--accent);
    font-weight: 520;
  }

  .page-hero > p:last-child {
    margin-top: 1rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .post-list {
    margin-top: 2rem;
    list-style: none;
  }

  .post-list li + li {
    margin-top: 0.8rem;
  }

  .post-list a {
    padding: clamp(1.3rem, 2.5vw, 1.85rem);
    display: grid;
    grid-template-columns: 54px minmax(0, 1fr) 42px;
    align-items: start;
    gap: 1.15rem;
    overflow: hidden;
    border: 1px solid var(--glass-stroke-muted);
    border-radius: var(--radius-md);
    background: var(--glass-fill);
    color: inherit;
    text-decoration: none;
    transition:
      transform 220ms var(--ease-out),
      border-color 180ms ease,
      background-color 180ms ease,
      box-shadow 220ms ease;
  }

  .post-list a:hover {
    border-color: var(--glass-stroke);
    background: var(--glass-fill-strong);
    box-shadow:
      var(--glass-shadow-hover),
      inset 0 1px 0 var(--glass-highlight);
    transform: translateY(-3px);
  }

  .post-index {
    padding-top: 0.15rem;
    color: var(--text-tertiary);
    font-size: 0.7rem;
    font-weight: 680;
    letter-spacing: 0.08em;
  }

  .post-list time {
    display: inline-flex;
    align-items: center;
    gap: 0.38rem;
    color: var(--text-tertiary);
    font-size: 0.74rem;
  }

  .post-list h2 {
    margin-top: 0.65rem;
    color: var(--text-primary);
    font-size: clamp(1.14rem, 2.2vw, 1.45rem);
    font-weight: 650;
    letter-spacing: -0.03em;
    line-height: 1.45;
    transition: color 180ms ease;
  }

  .post-list a:hover h2 {
    color: var(--accent-strong);
  }

  .post-list article > p {
    max-width: 860px;
    margin-top: 0.6rem;
    color: var(--text-secondary);
    font-size: 0.87rem;
    line-height: 1.75;
  }

  .post-arrow {
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border);
    border-radius: 12px;
    color: var(--text-tertiary);
    transition:
      color 180ms ease,
      background-color 180ms ease,
      border-color 180ms ease,
      transform 220ms var(--ease-out);
  }

  .post-list a:hover .post-arrow {
    border-color: transparent;
    background: var(--accent-soft);
    color: var(--accent-strong);
    transform: translate(2px, -2px) rotate(4deg);
  }

  @media (max-width: 640px) {
    .page-hero {
      padding: 0.5rem 0 3rem;
    }

    .eyebrow {
      margin-top: 2.5rem;
    }

    .post-list {
      margin-top: 1rem;
    }

    .post-list a {
      padding: 1.25rem;
      grid-template-columns: minmax(0, 1fr) 36px;
      gap: 0.75rem;
    }

    .post-index {
      display: none;
    }

    .post-list article > p {
      display: -webkit-box;
      overflow: hidden;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 3;
    }

    .post-arrow {
      width: 36px;
      height: 36px;
    }
  }
</style>
