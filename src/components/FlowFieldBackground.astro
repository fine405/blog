<div class="flow-field-background" aria-hidden="true">
  <canvas class="flow-field-canvas"></canvas>
</div>

<script is:inline>
  (() => {
    const VERTEX_SHADER = `
      attribute vec2 a_position;
      varying vec2 v_uv;

      void main() {
        v_uv = (a_position + 1.0) * 0.5;
        gl_Position = vec4(a_position, 0.0, 1.0);
      }
    `;

    const FRAGMENT_SHADER = `
      precision highp float;

      uniform vec2 u_resolution;
      uniform vec2 u_pointer;
      uniform vec2 u_velocity;
      uniform float u_cell_size;
      uniform float u_pointer_strength;
      uniform float u_theme;
      uniform float u_time;

      varying vec2 v_uv;

      float hash(vec2 point) {
        return fract(sin(dot(point, vec2(127.1, 311.7))) * 43758.5453123);
      }

      float noise(vec2 point) {
        vec2 cell = floor(point);
        vec2 local = fract(point);
        vec2 curve = local * local * (3.0 - 2.0 * local);

        float a = hash(cell);
        float b = hash(cell + vec2(1.0, 0.0));
        float c = hash(cell + vec2(0.0, 1.0));
        float d = hash(cell + vec2(1.0, 1.0));

        return mix(mix(a, b, curve.x), mix(c, d, curve.x), curve.y);
      }

      float softEllipse(vec2 point, vec2 center, vec2 radius) {
        float distanceToCenter = length((point - center) / radius);
        return 1.0 - smoothstep(0.54, 1.27, distanceToCenter);
      }

      float halftone(float field, vec2 samplePosition) {
        vec2 local = fract(samplePosition / u_cell_size) - 0.5;
        float distanceToDot = length(local);
        float radius = smoothstep(0.0, 1.0, field) * 0.77;
        float dot = 1.0 - smoothstep(max(0.0, radius - 0.07), radius + 0.035, distanceToDot);
        float presence = smoothstep(0.018, 0.11, field);
        float solidCenter = smoothstep(0.92, 1.0, field);
        return max(dot * presence, solidCenter);
      }

      void main() {
        float aspect = u_resolution.x / max(u_resolution.y, 1.0);
        float landscapeMix = smoothstep(0.78, 1.18, aspect);
        float slowTime = u_time * 0.045;
        vec2 point = (v_uv - 0.5) * vec2(aspect, 1.0);

        vec2 pointerPoint = (u_pointer - 0.5) * vec2(aspect, 1.0);
        vec2 pointerDelta = point - pointerPoint;
        float pointerDistance = length(pointerDelta);
        vec2 pointerDirection = pointerDelta / max(pointerDistance, 0.0001);
        float pointerInfluence = exp(-pointerDistance * pointerDistance * 33.0) * u_pointer_strength;
        vec2 velocity = u_velocity * vec2(aspect, 1.0);
        float velocityStrength = min(length(velocity) * 36.0, 1.0);
        vec2 tangent = vec2(-pointerDirection.y, pointerDirection.x);

        float firstNoise = noise(point * 1.16 + vec2(slowTime, -slowTime * 0.71));
        float secondNoise = noise(point * 1.72 + vec2(-slowTime * 0.58, slowTime * 0.84));
        vec2 domainWarp = vec2(firstNoise - 0.5, secondNoise - 0.5) * 0.23;
        domainWarp += vec2(
          sin(point.y * 2.7 + slowTime * 2.2),
          cos(point.x * 2.35 - slowTime * 1.8)
        ) * 0.035;
        domainWarp += pointerDirection * pointerInfluence * 0.105;
        domainWarp += tangent * pointerInfluence * velocityStrength * 0.025;
        vec2 flowingPoint = point + domainWarp;

        vec2 creamCenter = vec2(
          -0.25 + sin(slowTime * 1.06) * 0.07,
          0.17 + cos(slowTime * 0.82) * 0.045
        );
        vec2 redCenter = vec2(
          -0.12 + cos(slowTime * 0.69) * 0.09,
          -0.78 + sin(slowTime * 0.88) * 0.045
        );
        vec2 glowCenter = vec2(
          mix(0.04, 0.30, landscapeMix) + sin(slowTime * 0.78) * 0.04,
          -0.04 + cos(slowTime * 0.68) * 0.028
        );

        float cream = max(
          softEllipse(flowingPoint, creamCenter, vec2(0.95, 0.55)),
          softEllipse(flowingPoint, vec2(aspect * 0.27, 0.46), vec2(0.68, 0.38)) * 0.68
        );
        float red = softEllipse(flowingPoint, redCenter, vec2(0.96, 0.60));
        float glow = softEllipse(flowingPoint, glowCenter, vec2(mix(0.16, 0.33, landscapeMix), 0.24));

        float parting = 1.0 - pointerInfluence * 0.74;
        cream *= parting;
        red *= parting;
        glow *= parting * (1.0 - red * 0.74) * 0.72;

        vec2 pushedGrid = gl_FragCoord.xy;
        pushedGrid += pointerDirection * pointerInfluence * u_cell_size * 1.8;
        pushedGrid += tangent * pointerInfluence * velocityStrength * u_cell_size * 0.65;

        float creamPattern = halftone(cream, pushedGrid);
        float glowPattern = halftone(glow, pushedGrid + vec2(u_cell_size * 0.21));
        float redPattern = halftone(red, pushedGrid + vec2(u_cell_size * 0.09, -u_cell_size * 0.13));

        vec3 lightBase = vec3(0.957, 0.804, 0.714);
        vec3 lightCream = vec3(1.0, 0.984, 0.945);
        vec3 lightRed = vec3(0.84, 0.31, 0.21);
        vec3 lightGlow = vec3(0.94, 0.79, 0.52);

        vec3 darkBase = vec3(0.075, 0.059, 0.059);
        vec3 darkCream = vec3(0.18, 0.14, 0.13);
        vec3 darkRed = vec3(0.40, 0.14, 0.11);
        vec3 darkGlow = vec3(0.32, 0.24, 0.12);

        vec3 base = mix(lightBase, darkBase, u_theme);
        vec3 creamColor = mix(lightCream, darkCream, u_theme);
        vec3 redColor = mix(lightRed, darkRed, u_theme);
        vec3 glowColor = mix(lightGlow, darkGlow, u_theme);

        float lightAmount = mix(0.62, 0.30, u_theme);
        float chromaAmount = mix(0.46, 0.38, u_theme);
        vec3 color = base;
        color = mix(color, creamColor, creamPattern * lightAmount);
        color = mix(color, glowColor, glowPattern * chromaAmount * 0.42);
        color = mix(color, redColor, redPattern * chromaAmount);

        float softVeil = mix(0.12, 0.035, u_theme);
        color = mix(color, mix(vec3(1.0), darkBase, u_theme), softVeil);
        gl_FragColor = vec4(color, 1.0);
      }
    `;

    function compileShader(gl, type, source) {
      const shader = gl.createShader(type);
      if (!shader) return null;
      gl.shaderSource(shader, source);
      gl.compileShader(shader);

      if (!gl.getShaderParameter(shader, gl.COMPILE_STATUS)) {
        console.warn('Flow field shader could not compile:', gl.getShaderInfoLog(shader));
        gl.deleteShader(shader);
        return null;
      }

      return shader;
    }

    function createProgram(gl) {
      const vertexShader = compileShader(gl, gl.VERTEX_SHADER, VERTEX_SHADER);
      const fragmentShader = compileShader(gl, gl.FRAGMENT_SHADER, FRAGMENT_SHADER);
      if (!vertexShader || !fragmentShader) return null;

      const program = gl.createProgram();
      if (!program) return null;
      gl.attachShader(program, vertexShader);
      gl.attachShader(program, fragmentShader);
      gl.linkProgram(program);
      gl.deleteShader(vertexShader);
      gl.deleteShader(fragmentShader);

      if (!gl.getProgramParameter(program, gl.LINK_STATUS)) {
        console.warn('Flow field shader could not link:', gl.getProgramInfoLog(program));
        gl.deleteProgram(program);
        return null;
      }

      return program;
    }

    function initFlowFieldBackground() {
      window.__flowFieldBackground?.destroy?.();

      const canvas = document.querySelector('.flow-field-canvas');
      if (!(canvas instanceof HTMLCanvasElement)) return;

      const gl = canvas.getContext('webgl', {
        alpha: false,
        antialias: false,
        depth: false,
        powerPreference: 'low-power',
        preserveDrawingBuffer: false,
        stencil: false,
      });
      if (!gl) {
        canvas.dataset.fallback = 'true';
        return;
      }

      const program = createProgram(gl);
      if (!program) {
        canvas.dataset.fallback = 'true';
        return;
      }

      const positionLocation = gl.getAttribLocation(program, 'a_position');
      const uniforms = {
        resolution: gl.getUniformLocation(program, 'u_resolution'),
        pointer: gl.getUniformLocation(program, 'u_pointer'),
        velocity: gl.getUniformLocation(program, 'u_velocity'),
        cellSize: gl.getUniformLocation(program, 'u_cell_size'),
        pointerStrength: gl.getUniformLocation(program, 'u_pointer_strength'),
        theme: gl.getUniformLocation(program, 'u_theme'),
        time: gl.getUniformLocation(program, 'u_time'),
      };
      const buffer = gl.createBuffer();
      if (!buffer || positionLocation < 0) return;

      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const finePointer = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
      const compactViewport = window.matchMedia('(max-width: 640px)').matches;
      const targetFrameDuration = 1000 / (compactViewport ? 22 : 30);
      const pointer = { currentX: 0.5, currentY: 0.52, targetX: 0.5, targetY: 0.52 };
      let pointerStrength = 0;
      let targetPointerStrength = 0;
      let velocityX = 0;
      let velocityY = 0;
      let themeValue = document.documentElement.dataset.theme === 'dark' ? 1 : 0;
      let targetTheme = themeValue;
      let cellSize = 6;
      let animationFrame = 0;
      let lastRender = 0;
      let destroyed = false;

      gl.useProgram(program);
      gl.bindBuffer(gl.ARRAY_BUFFER, buffer);
      gl.bufferData(
        gl.ARRAY_BUFFER,
        new Float32Array([-1, -1, 3, -1, -1, 3]),
        gl.STATIC_DRAW
      );
      gl.enableVertexAttribArray(positionLocation);
      gl.vertexAttribPointer(positionLocation, 2, gl.FLOAT, false, 0, 0);
      gl.disable(gl.BLEND);
      gl.disable(gl.DEPTH_TEST);

      function resize() {
        const width = Math.max(1, window.innerWidth);
        const height = Math.max(1, window.innerHeight);
        const dpr = Math.min(window.devicePixelRatio || 1, 1);
        const nextWidth = Math.round(width * dpr);
        const nextHeight = Math.round(height * dpr);

        if (canvas.width !== nextWidth || canvas.height !== nextHeight) {
          canvas.width = nextWidth;
          canvas.height = nextHeight;
        }

        cellSize = (width < 640 ? 7 : width > 1800 ? 7 : 6) * dpr;
        gl.viewport(0, 0, nextWidth, nextHeight);
      }

      function render(timestamp) {
        if (destroyed) return;
        animationFrame = window.requestAnimationFrame(render);
        if (!reduceMotion && timestamp - lastRender < targetFrameDuration) return;
        lastRender = timestamp;

        const previousX = pointer.currentX;
        const previousY = pointer.currentY;
        const follow = reduceMotion ? 1 : 0.095;
        pointer.currentX += (pointer.targetX - pointer.currentX) * follow;
        pointer.currentY += (pointer.targetY - pointer.currentY) * follow;
        velocityX += ((pointer.currentX - previousX) - velocityX) * 0.18;
        velocityY += ((pointer.currentY - previousY) - velocityY) * 0.18;
        pointerStrength += (targetPointerStrength - pointerStrength) * 0.075;
        themeValue += (targetTheme - themeValue) * 0.065;

        gl.useProgram(program);
        gl.uniform2f(uniforms.resolution, canvas.width, canvas.height);
        gl.uniform2f(uniforms.pointer, pointer.currentX, pointer.currentY);
        gl.uniform2f(uniforms.velocity, velocityX, velocityY);
        gl.uniform1f(uniforms.cellSize, cellSize);
        gl.uniform1f(uniforms.pointerStrength, reduceMotion ? 0 : pointerStrength);
        gl.uniform1f(uniforms.theme, themeValue);
        gl.uniform1f(uniforms.time, reduceMotion ? 0 : timestamp / 1000);
        gl.drawArrays(gl.TRIANGLES, 0, 3);

        if (reduceMotion) {
          window.cancelAnimationFrame(animationFrame);
          animationFrame = 0;
        }
      }

      function handlePointerMove(event) {
        if (!finePointer || reduceMotion) return;
        pointer.targetX = Math.max(0, Math.min(1, event.clientX / window.innerWidth));
        pointer.targetY = 1 - Math.max(0, Math.min(1, event.clientY / window.innerHeight));
        targetPointerStrength = 1;
      }

      function handlePointerLeave(event) {
        if (event.relatedTarget === null) targetPointerStrength = 0;
      }

      function handleVisibilityChange() {
        if (document.hidden) {
          window.cancelAnimationFrame(animationFrame);
          animationFrame = 0;
          return;
        }
        if (!animationFrame) animationFrame = window.requestAnimationFrame(render);
      }

      const themeObserver = new MutationObserver(() => {
        targetTheme = document.documentElement.dataset.theme === 'dark' ? 1 : 0;
        if (reduceMotion) {
          themeValue = targetTheme;
          if (!animationFrame) animationFrame = window.requestAnimationFrame(render);
        }
      });

      resize();
      window.addEventListener('resize', resize, { passive: true });
      window.addEventListener('pointermove', handlePointerMove, { passive: true });
      document.documentElement.addEventListener('pointerleave', handlePointerLeave, { passive: true });
      document.addEventListener('visibilitychange', handleVisibilityChange);
      themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
      animationFrame = window.requestAnimationFrame(render);

      window.__flowFieldBackground = {
        destroy() {
          destroyed = true;
          window.cancelAnimationFrame(animationFrame);
          window.removeEventListener('resize', resize);
          window.removeEventListener('pointermove', handlePointerMove);
          document.documentElement.removeEventListener('pointerleave', handlePointerLeave);
          document.removeEventListener('visibilitychange', handleVisibilityChange);
          themeObserver.disconnect();
          gl.deleteBuffer(buffer);
          gl.deleteProgram(program);
        },
      };
    }

    window.__initFlowFieldBackground = initFlowFieldBackground;
    initFlowFieldBackground();

    if (!window.__flowFieldPageLoadBound) {
      document.addEventListener('astro:page-load', () => window.__initFlowFieldBackground?.());
      window.__flowFieldPageLoadBound = true;
    }
  })();
</script>

<style>
  .flow-field-background {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    background: var(--flow-background, var(--bg));
    pointer-events: none;
    transition: background-color 320ms ease;
  }

  .flow-field-canvas {
    width: 100%;
    height: 100%;
    display: block;
    opacity: 0.84;
    transition: opacity 240ms ease;
  }

  :global([data-theme='dark']) .flow-field-canvas {
    opacity: 0.9;
  }

  @media (max-width: 640px) {
    .flow-field-canvas {
      opacity: 0.68;
    }

    :global([data-theme='dark']) .flow-field-canvas {
      opacity: 0.8;
    }
  }

  @media print {
    .flow-field-background {
      display: none;
    }
  }
</style>
