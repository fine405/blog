---
interface Props {
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  schemaType?: 'WebSite' | 'WebPage' | 'CollectionPage' | 'AboutPage' | 'BlogPosting';
  schemaTitle?: string;
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
  canonicalURL?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  image = '/og-default.png',
  imageAlt = title,
  type = 'website',
  schemaType,
  schemaTitle,
  publishedTime,
  modifiedTime,
  tags = [],
  canonicalURL = Astro.url.href,
  noindex = false,
} = Astro.props;

const siteName = 'Fine - 博客';
const siteUrl = (Astro.site?.toString() || 'https://fine405.vercel.app').replace(/\/+$/, '');
const canonical = new URL(canonicalURL, `${siteUrl}/`);
canonical.hash = '';
canonical.search = '';
const canonicalHref = canonical.toString();
const fullImageUrl = new URL(image, `${siteUrl}/`).toString();
const locale = 'zh_CN';
const language = 'zh-CN';
const authorInfo = {
  '@type': 'Person',
  name: 'Fine',
  url: `${siteUrl}/`,
  sameAs: ['https://github.com/fine405'],
};

const pageSchemaType = (() => {
  if (type === 'article') return 'BlogPosting';
  if (schemaType) return schemaType;
  return canonical.pathname === '/' ? 'WebSite' : 'WebPage';
})();

const pageName = schemaTitle || title;
const robotsContent = noindex
  ? 'noindex, nofollow'
  : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';

const webpageSchema = {
  '@context': 'https://schema.org',
  '@type': pageSchemaType,
  name: pageName,
  description,
  url: canonicalHref,
  inLanguage: language,
  isPartOf: {
    '@type': 'WebSite',
    name: siteName,
    url: `${siteUrl}/`,
  },
  author: authorInfo,
};

// JSON-LD 结构化数据
const jsonLd = type === 'article'
  ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: pageName,
      description,
      image: [fullImageUrl],
      url: canonicalHref,
      datePublished: publishedTime?.toISOString(),
      dateModified: (modifiedTime ?? publishedTime)?.toISOString(),
      inLanguage: language,
      author: authorInfo,
      publisher: authorInfo,
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': canonicalHref,
      },
      keywords: tags.length > 0 ? tags.join(', ') : undefined,
    }
  : pageSchemaType === 'WebSite'
  ? {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: siteName,
      description,
      url: canonicalHref,
      inLanguage: language,
      author: authorInfo,
    }
  : {
      ...webpageSchema,
    };
---

<!-- 基础 Meta -->
<meta name="description" content={description} />
<meta name="author" content="Fine" />
<meta name="robots" content={robotsContent} />
<meta name="googlebot" content={robotsContent} />
<meta name="referrer" content="strict-origin-when-cross-origin" />
{tags.length > 0 && <meta name="keywords" content={tags.join(', ')} />}
<link rel="canonical" href={canonicalHref} />
<link rel="alternate" hreflang={language} href={canonicalHref} />
<link rel="alternate" hreflang="x-default" href={canonicalHref} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalHref} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullImageUrl} />
<meta property="og:image:alt" content={imageAlt} />
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content={locale} />

{type === 'article' && publishedTime && (
  <>
    <meta property="article:published_time" content={publishedTime.toISOString()} />
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime.toISOString()} />}
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}
  </>
)}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImageUrl} />
<meta name="twitter:image:alt" content={imageAlt} />

<!-- JSON-LD 结构化数据 -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
