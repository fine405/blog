---
// 图片 Lightbox 组件 - 支持全屏、下载、左右导航
---

<script>
  import GLightbox from 'glightbox';
  import 'glightbox/dist/css/glightbox.min.css';

  interface LightboxWindow extends Window {
    __glightboxInstance?: ReturnType<typeof GLightbox>;
    __imageLightboxPageLoadHandler?: () => void;
  }

  const lightboxWindow = window as LightboxWindow;

  function initLightbox() {
    // 获取文章内容区域的所有图片
    const contentImages = document.querySelectorAll<HTMLImageElement>('.content img');

    contentImages.forEach((img) => {
      // 添加 glightbox class 和 data 属性
      img.classList.add('glightbox');
      img.setAttribute('data-gallery', 'post-images');
      img.style.cursor = 'zoom-in';
    });

    const existing = lightboxWindow.__glightboxInstance;
    if (existing && typeof existing.destroy === 'function') {
      existing.destroy();
    }

    // 初始化 GLightbox
    if (contentImages.length > 0) {
      lightboxWindow.__glightboxInstance = GLightbox({
        selector: '.glightbox',
        touchNavigation: true,
        loop: true,
        autoplayVideos: true,
        descPosition: 'bottom',
        svg: {
          close: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>',
          prev: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>',
          next: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>',
        },
      });
      return;
    }

    lightboxWindow.__glightboxInstance = undefined;
  }

  initLightbox();

  if (lightboxWindow.__imageLightboxPageLoadHandler) {
    document.removeEventListener('astro:page-load', lightboxWindow.__imageLightboxPageLoadHandler);
  }
  lightboxWindow.__imageLightboxPageLoadHandler = initLightbox;
  document.addEventListener('astro:page-load', lightboxWindow.__imageLightboxPageLoadHandler);
</script>

<style is:global>
  .goverlay {
    background:
      radial-gradient(circle at 18% 8%, rgba(68, 111, 224, 0.2), transparent 32rem),
      radial-gradient(circle at 82% 16%, rgba(137, 83, 211, 0.16), transparent 28rem),
      rgba(5, 9, 17, 0.82) !important;
    -webkit-backdrop-filter: blur(24px) saturate(1.15);
    backdrop-filter: blur(24px) saturate(1.15);
  }

  .gslide-description {
    background: transparent !important;
  }

  .gdesc-inner {
    padding: 1rem 1.25rem !important;
    color: rgba(255, 255, 255, 0.86) !important;
  }

  .gclose, .gnext, .gprev {
    border: 1px solid rgba(255, 255, 255, 0.26) !important;
    border-radius: 16px !important;
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0.07)) !important;
    width: 44px !important;
    height: 44px !important;
    box-shadow:
      0 16px 36px rgba(0, 0, 0, 0.24),
      inset 0 1px 0 rgba(255, 255, 255, 0.34) !important;
    -webkit-backdrop-filter: blur(18px) saturate(1.25);
    backdrop-filter: blur(18px) saturate(1.25);
    transition: background-color 180ms ease, transform 180ms ease !important;
  }

  .gclose:hover, .gnext:hover, .gprev:hover {
    border-color: rgba(255, 255, 255, 0.38) !important;
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0.11)) !important;
    transform: translateY(-2px) !important;
  }

  .gslide-image img {
    max-height: 90vh !important;
    border: 1px solid rgba(255, 255, 255, 0.18) !important;
    border-radius: 20px !important;
    box-shadow: 0 30px 90px rgba(0, 0, 0, 0.48), inset 0 1px 0 rgba(255, 255, 255, 0.18) !important;
  }

  .gslide-title {
    font-size: 0.82rem !important;
    color: rgba(255, 255, 255, 0.7) !important;
  }
</style>
