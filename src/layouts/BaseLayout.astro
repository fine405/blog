---
import SEO from '../components/SEO.astro';
import { ClientRouter } from 'astro:transitions';
import {
  ArrowUp,
  GitFork,
  Menu,
  Moon,
  Rss,
  Sun,
  X,
} from '@lucide/astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  schemaType?: 'WebSite' | 'WebPage' | 'CollectionPage' | 'AboutPage' | 'BlogPosting';
  schemaTitle?: string;
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
  canonicalURL?: string;
  noindex?: boolean;
}

const {
  title,
  description = '一个专注于开发技术的个人博客',
  image,
  imageAlt,
  type = 'website',
  schemaType,
  schemaTitle,
  publishedTime,
  modifiedTime,
  tags = [],
  canonicalURL,
  noindex = false,
} = Astro.props;

const pathname = Astro.url.pathname;
const navItems = [
  { href: '/', label: '首页' },
  { href: '/blog', label: '文章' },
  { href: '/tags', label: '标签' },
  { href: '/about', label: '关于' },
];
const isActive = (href: string) => href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<!doctype html>
<html lang="zh-CN" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f7f8fb" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="https://github.com/fine405.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="Fine - RSS Feed" href="/rss.xml" />
    <SEO
      title={title}
      description={description}
      image={image}
      imageAlt={imageAlt}
      type={type}
      schemaType={schemaType}
      schemaTitle={schemaTitle}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      tags={tags}
      canonicalURL={canonicalURL}
      noindex={noindex}
    />
    <title>{title}</title>
    <script is:inline>
      (() => {
        try {
          const savedTheme = localStorage.getItem('theme');
          document.documentElement.dataset.theme = savedTheme === 'dark' ? 'dark' : 'light';
          document.documentElement.classList.add('js');
        } catch {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#main-content">跳到主要内容</a>

    <div class="site-shell">
      <header class="site-header">
        <nav class="site-nav" aria-label="主导航">
          <a href="/" class="brand" aria-label="Fine 首页">
            <span class="brand-name">Fine<span aria-hidden="true">.</span></span>
            <span class="brand-note">Build · Think · Share</span>
          </a>

          <div class="nav-links" id="primary-navigation">
            {navItems.map((item) => (
              <a
                href={item.href}
                class:list={{ active: isActive(item.href) }}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            ))}

            <div class="mobile-social-links" aria-label="其他链接">
              <a href="https://github.com/fine405" target="_blank" rel="noopener noreferrer">
                <GitFork size={18} stroke-width={1.8} aria-hidden="true" />
                GitHub
              </a>
              <a href="/rss.xml" target="_blank" rel="noopener noreferrer">
                <Rss size={18} stroke-width={1.8} aria-hidden="true" />
                RSS
              </a>
            </div>
          </div>

          <div class="nav-actions">
            <a
              href="https://github.com/fine405"
              target="_blank"
              rel="noopener noreferrer"
              class="icon-button desktop-social"
              aria-label="访问 Fine 的 GitHub"
              title="GitHub"
            >
              <GitFork size={18} stroke-width={1.8} aria-hidden="true" />
            </a>
            <a
              href="/rss.xml"
              target="_blank"
              rel="noopener noreferrer"
              class="icon-button desktop-social"
              aria-label="订阅 RSS"
              title="RSS 订阅"
            >
              <Rss size={17} stroke-width={1.8} aria-hidden="true" />
            </a>
            <button id="theme-toggle" class="icon-button" type="button" aria-label="切换到深色主题">
              <Moon class="moon" size={18} stroke-width={1.8} aria-hidden="true" />
              <Sun class="sun" size={18} stroke-width={1.8} aria-hidden="true" />
            </button>
            <button
              id="menu-toggle"
              class="icon-button menu-toggle"
              type="button"
              aria-label="打开菜单"
              aria-controls="primary-navigation"
              aria-expanded="false"
            >
              <Menu class="menu-icon" size={20} stroke-width={1.8} aria-hidden="true" />
              <X class="close-icon" size={20} stroke-width={1.8} aria-hidden="true" />
            </button>
          </div>
        </nav>
      </header>

      <main id="main-content" class="page-main">
        <slot />
      </main>

      <footer class="site-footer">
        <div>
          <a href="/" class="footer-brand">Fine<span aria-hidden="true">.</span></a>
          <p>记录 AI、工程与创造之间值得复用的经验。</p>
        </div>
        <div class="footer-meta">
          <div class="footer-links">
            <a href="/blog">文章</a>
            <a href="/tags">标签</a>
            <a href="/about">关于</a>
            <a href="/rss.xml">RSS</a>
          </div>
          <p>&copy; {new Date().getFullYear()} Fine. Built with care.</p>
        </div>
      </footer>
    </div>

    <button id="back-to-top" class="back-to-top" type="button" aria-label="返回页面顶部" title="返回顶部">
      <ArrowUp size={18} stroke-width={1.9} aria-hidden="true" />
    </button>

    <script is:inline>
      function initTheme() {
        const savedTheme = localStorage.getItem('theme');
        const theme = savedTheme === 'dark' ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', theme);
        updateThemeUI(theme);
      }

      function updateThemeUI(theme) {
        const themeToggle = document.getElementById('theme-toggle');
        const themeMeta = document.querySelector('meta[name="theme-color"]');
        const nextLabel = theme === 'dark' ? '切换到浅色主题' : '切换到深色主题';

        if (themeToggle) {
          themeToggle.setAttribute('aria-label', nextLabel);
          themeToggle.setAttribute('title', nextLabel);
        }
        if (themeMeta) {
          themeMeta.setAttribute('content', theme === 'dark' ? '#10131b' : '#f7f8fb');
        }
      }

      function setupThemeToggle() {
        const themeToggle = document.getElementById('theme-toggle');
        if (!themeToggle || themeToggle.dataset.bound === 'true') return;

        themeToggle.dataset.bound = 'true';
        themeToggle.addEventListener('click', () => {
          const current = document.documentElement.getAttribute('data-theme');
          const next = current === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          localStorage.setItem('theme', next);
          updateThemeUI(next);
        });
      }

      function setupMenuToggle() {
        const menuToggle = document.getElementById('menu-toggle');
        const navLinks = document.getElementById('primary-navigation');
        if (!menuToggle || !navLinks) return;

        const closeMenu = () => {
          navLinks.classList.remove('open');
          menuToggle.classList.remove('open');
          menuToggle.setAttribute('aria-expanded', 'false');
          menuToggle.setAttribute('aria-label', '打开菜单');
          document.body.classList.remove('menu-open');
        };

        if (menuToggle.dataset.bound !== 'true') {
          menuToggle.dataset.bound = 'true';
          menuToggle.addEventListener('click', () => {
            const willOpen = !navLinks.classList.contains('open');
            navLinks.classList.toggle('open', willOpen);
            menuToggle.classList.toggle('open', willOpen);
            menuToggle.setAttribute('aria-expanded', String(willOpen));
            menuToggle.setAttribute('aria-label', willOpen ? '关闭菜单' : '打开菜单');
            document.body.classList.toggle('menu-open', willOpen);
          });
        }

        if (navLinks.dataset.bound !== 'true') {
          navLinks.dataset.bound = 'true';
          navLinks.addEventListener('click', (event) => {
            const target = event.target;
            if (target instanceof Element && target.closest('a')) closeMenu();
          });
        }

        if (window['__baseLayoutEscapeHandler']) {
          document.removeEventListener('keydown', window['__baseLayoutEscapeHandler']);
        }
        window['__baseLayoutEscapeHandler'] = (event) => {
          if (event.key === 'Escape') closeMenu();
        };
        document.addEventListener('keydown', window['__baseLayoutEscapeHandler']);
      }

      function setupBackToTop() {
        const button = document.getElementById('back-to-top');
        const header = document.querySelector('.site-header');
        if (!button) return;

        if (window['__backToTopScrollHandler']) {
          window.removeEventListener('scroll', window['__backToTopScrollHandler']);
        }
        const updateVisibility = () => {
          button.classList.toggle('visible', window.scrollY > 560);
          header?.classList.toggle('scrolled', window.scrollY > 24);
        };
        window['__backToTopScrollHandler'] = updateVisibility;
        window.addEventListener('scroll', updateVisibility, { passive: true });
        updateVisibility();

        if (button.dataset.bound !== 'true') {
          button.dataset.bound = 'true';
          button.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
        }
      }

      function setupRevealMotion() {
        const items = document.querySelectorAll('[data-reveal]');
        if (window['__revealObserver']) {
          window['__revealObserver'].disconnect();
        }
        if (!items.length) return;

        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduceMotion || !('IntersectionObserver' in window)) {
          items.forEach((item) => item.classList.add('is-visible'));
          return;
        }

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          });
        }, {
          rootMargin: '0px 0px -8% 0px',
          threshold: 0.08,
        });

        items.forEach((item) => observer.observe(item));
        window['__revealObserver'] = observer;
      }

      function initLayout() {
        document.body.classList.remove('menu-open');
        initTheme();
        setupThemeToggle();
        setupMenuToggle();
        setupBackToTop();
        setupRevealMotion();
      }

      initLayout();

      if (!window['__baseLayoutPageLoadBound']) {
        document.addEventListener('astro:page-load', initLayout);
        window['__baseLayoutPageLoadBound'] = true;
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f7f8fb;
    --bg-secondary: #f0f2f7;
    --surface: rgba(255, 255, 255, 0.82);
    --surface-solid: #ffffff;
    --surface-soft: rgba(255, 255, 255, 0.56);
    --text: #1b2030;
    --text-primary: #101522;
    --text-secondary: #667085;
    --text-tertiary: #98a0b2;
    --accent: #3f5bd8;
    --accent-strong: #2f49c3;
    --accent-soft: #edf0ff;
    --accent-faint: rgba(63, 91, 216, 0.09);
    --border: rgba(24, 34, 58, 0.1);
    --border-strong: rgba(24, 34, 58, 0.16);
    --code-bg: #eff1f6;
    --shadow-xs: 0 1px 2px rgba(16, 24, 40, 0.04);
    --shadow-sm: 0 8px 28px rgba(35, 43, 68, 0.07);
    --shadow-md: 0 20px 60px rgba(35, 43, 68, 0.11);
    --radius-sm: 10px;
    --radius-md: 16px;
    --radius-lg: 24px;
    --radius-xl: 32px;
    --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
  }

  [data-theme='dark'] {
    color-scheme: dark;
    --bg: #10131b;
    --bg-secondary: #171b26;
    --surface: rgba(24, 29, 41, 0.84);
    --surface-solid: #191e2a;
    --surface-soft: rgba(25, 30, 42, 0.62);
    --text: #d8dce7;
    --text-primary: #f4f6fb;
    --text-secondary: #9ba3b6;
    --text-tertiary: #6f788e;
    --accent: #91a2ff;
    --accent-strong: #acb8ff;
    --accent-soft: rgba(114, 136, 255, 0.13);
    --accent-faint: rgba(114, 136, 255, 0.1);
    --border: rgba(231, 235, 246, 0.1);
    --border-strong: rgba(231, 235, 246, 0.18);
    --code-bg: #1a1f2c;
    --shadow-xs: 0 1px 2px rgba(0, 0, 0, 0.12);
    --shadow-sm: 0 10px 32px rgba(0, 0, 0, 0.2);
    --shadow-md: 0 24px 70px rgba(0, 0, 0, 0.3);
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  * {
    margin: 0;
    padding: 0;
  }

  html {
    background: var(--bg);
    color: var(--text);
    font-family: Inter, ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI',
      'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
    font-synthesis: none;
    scroll-behavior: smooth;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
  }

  body {
    min-width: 320px;
    min-height: 100vh;
    background:
      radial-gradient(circle at 14% -8%, var(--accent-faint), transparent 31rem),
      radial-gradient(circle at 88% 6%, rgba(99, 126, 234, 0.055), transparent 25rem),
      var(--bg);
    color: var(--text);
    transition: background-color 240ms ease, color 240ms ease;
  }

  body.menu-open {
    overflow: hidden;
  }

  ::selection {
    background: rgba(63, 91, 216, 0.2);
    color: var(--text-primary);
  }

  :focus-visible {
    outline: 3px solid rgba(63, 91, 216, 0.28);
    outline-offset: 3px;
    border-radius: 6px;
  }

  a,
  button {
    -webkit-tap-highlight-color: transparent;
  }

  button,
  input,
  textarea,
  select {
    font: inherit;
  }

  a {
    color: var(--accent);
    text-underline-offset: 0.18em;
  }

  .skip-link {
    position: fixed;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 1000;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    background: var(--surface-solid);
    color: var(--text-primary);
    font-size: 0.875rem;
    font-weight: 650;
    text-decoration: none;
    transform: translateY(-160%);
    transition: transform 180ms ease;
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .site-shell {
    width: min(1180px, calc(100% - 3rem));
    min-height: 100vh;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
  }

  .site-header {
    position: sticky;
    top: 1rem;
    z-index: 100;
    padding-top: 1rem;
  }

  .site-nav {
    min-height: 68px;
    padding: 0.55rem 0.65rem 0.55rem 1.25rem;
    display: grid;
    grid-template-columns: minmax(190px, 1fr) auto minmax(190px, 1fr);
    align-items: center;
    border: 1px solid var(--border);
    border-radius: 20px;
    background: var(--surface);
    box-shadow: var(--shadow-sm), inset 0 1px 0 rgba(255, 255, 255, 0.55);
    -webkit-backdrop-filter: blur(18px) saturate(1.25);
    backdrop-filter: blur(18px) saturate(1.25);
    transition:
      background-color 220ms ease,
      border-color 220ms ease,
      box-shadow 240ms ease,
      transform 240ms var(--ease-out);
  }

  .site-header.scrolled .site-nav {
    border-color: var(--border-strong);
    background: var(--surface-solid);
    box-shadow: var(--shadow-md), inset 0 1px 0 rgba(255, 255, 255, 0.58);
    transform: translateY(-2px);
  }

  [data-theme='dark'] .site-nav {
    box-shadow: var(--shadow-sm), inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .brand {
    width: fit-content;
    display: inline-flex;
    flex-direction: column;
    color: var(--text-primary);
    line-height: 1;
    text-decoration: none;
  }

  .brand-name {
    font-size: 1.28rem;
    font-weight: 780;
    letter-spacing: -0.045em;
  }

  .brand-name span,
  .footer-brand span {
    color: var(--accent);
  }

  .brand-note {
    margin-top: 0.35rem;
    color: var(--text-tertiary);
    font-size: 0.61rem;
    font-weight: 620;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.15rem;
  }

  .nav-links > a {
    padding: 0.65rem 0.9rem;
    border-radius: 10px;
    color: var(--text-secondary);
    font-size: 0.875rem;
    font-weight: 560;
    text-decoration: none;
    transition: color 180ms ease, background-color 180ms ease;
  }

  .nav-links > a:hover {
    background: var(--bg-secondary);
    color: var(--text-primary);
  }

  .nav-links > a.active {
    background: var(--accent-soft);
    color: var(--accent-strong);
  }

  .nav-actions {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 0.35rem;
  }

  .icon-button {
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
    border-radius: 11px;
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    text-decoration: none;
    transition:
      color 180ms ease,
      background-color 180ms ease,
      border-color 180ms ease,
      transform 180ms var(--ease-out);
  }

  .icon-button:hover {
    border-color: var(--border);
    background: var(--surface-solid);
    color: var(--text-primary);
    transform: translateY(-1px);
  }

  .icon-button:active {
    transform: translateY(0) scale(0.96);
  }

  .sun,
  .close-icon {
    display: none;
  }

  [data-theme='dark'] .sun,
  .menu-toggle.open .close-icon {
    display: block;
  }

  [data-theme='dark'] .moon,
  .menu-toggle.open .menu-icon {
    display: none;
  }

  .menu-toggle,
  .mobile-social-links {
    display: none;
  }

  .page-main {
    flex: 1;
    padding: 5.5rem 0 7rem;
  }

  .js .page-main {
    animation: page-enter 420ms var(--ease-out) both;
  }

  @keyframes page-enter {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .js [data-reveal] {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 640ms ease,
      transform 720ms var(--ease-out);
    transition-delay: var(--reveal-delay, 0ms);
    will-change: opacity, transform;
  }

  .js [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .site-footer {
    padding: 2.25rem 0 2.75rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    border-top: 1px solid var(--border);
    color: var(--text-secondary);
  }

  .footer-brand {
    color: var(--text-primary);
    font-size: 1.2rem;
    font-weight: 760;
    letter-spacing: -0.04em;
    text-decoration: none;
  }

  .site-footer > div > p {
    max-width: 25rem;
    margin-top: 0.55rem;
    font-size: 0.84rem;
    line-height: 1.6;
  }

  .footer-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.7rem;
  }

  .footer-links {
    display: flex;
    gap: 1.15rem;
  }

  .footer-links a {
    color: var(--text-secondary);
    font-size: 0.82rem;
    text-decoration: none;
    transition: color 180ms ease;
  }

  .footer-links a:hover {
    color: var(--text-primary);
  }

  .footer-meta > p {
    font-size: 0.76rem;
  }

  .back-to-top {
    position: fixed;
    right: max(1.25rem, calc((100vw - 1180px) / 2 - 4rem));
    bottom: 1.5rem;
    z-index: 80;
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--surface);
    box-shadow: var(--shadow-sm);
    color: var(--text-primary);
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transform: translateY(10px) scale(0.96);
    transition: opacity 180ms ease, transform 220ms var(--ease-out), background-color 180ms ease;
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
  }

  .back-to-top.visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }

  .back-to-top:hover {
    background: var(--surface-solid);
    transform: translateY(-2px);
  }

  code {
    padding: 0.18em 0.42em;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--code-bg);
    font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', monospace;
    font-size: 0.88em;
  }

  pre {
    overflow-x: auto;
    padding: 1.2rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--code-bg);
    box-shadow: var(--shadow-xs);
  }

  pre code {
    padding: 0;
    border: 0;
    background: transparent;
  }

  @media (max-width: 860px) {
    .site-nav {
      grid-template-columns: 1fr auto;
    }

    .nav-links {
      position: fixed;
      top: 6.3rem;
      right: 1.5rem;
      left: 1.5rem;
      padding: 0.75rem;
      display: grid;
      gap: 0.3rem;
      border: 1px solid var(--border);
      border-radius: 20px;
      background: var(--surface-solid);
      box-shadow: var(--shadow-md);
      opacity: 0;
      visibility: hidden;
      transform: translateY(-10px) scale(0.98);
      transform-origin: top center;
      transition:
        opacity 180ms ease,
        visibility 180ms ease,
        transform 220ms var(--ease-out);
    }

    .nav-links.open {
      opacity: 1;
      visibility: visible;
      transform: translateY(0) scale(1);
    }

    .nav-links > a {
      padding: 0.9rem 1rem;
      font-size: 1rem;
    }

    .mobile-social-links {
      margin-top: 0.35rem;
      padding-top: 0.7rem;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.45rem;
