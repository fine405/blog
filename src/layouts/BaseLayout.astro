---
import SEO from '../components/SEO.astro';
import FlowFieldBackground from '../components/FlowFieldBackground.astro';
import GitHubIcon from '../components/GitHubIcon.astro';
import { ClientRouter } from 'astro:transitions';
import {
  ArrowUp,
  Menu,
  Moon,
  Rss,
  Sun,
  X,
} from '@lucide/astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  schemaType?: 'WebSite' | 'WebPage' | 'CollectionPage' | 'AboutPage' | 'BlogPosting';
  schemaTitle?: string;
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
  canonicalURL?: string;
  noindex?: boolean;
  backgroundMotion?: boolean;
}

const {
  title,
  description = '一个专注于开发技术的个人博客',
  image,
  imageAlt,
  type = 'website',
  schemaType,
  schemaTitle,
  publishedTime,
  modifiedTime,
  tags = [],
  canonicalURL,
  noindex = false,
  backgroundMotion = true,
} = Astro.props;

const pathname = Astro.url.pathname;
const navItems = [
  { href: '/', label: '首页' },
  { href: '/blog', label: '文章' },
  { href: '/tags', label: '标签' },
  { href: '/about', label: '关于' },
];
const isActive = (href: string) => href === '/' ? pathname === '/' : pathname.startsWith(href);
const activeNavIndex = Math.max(navItems.findIndex((item) => isActive(item.href)), 0);
---

<!doctype html>
<html lang="zh-CN" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f4cdb6" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="https://github.com/fine405.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="Fine - RSS Feed" href="/rss.xml" />
    <SEO
      title={title}
      description={description}
      image={image}
      imageAlt={imageAlt}
      type={type}
      schemaType={schemaType}
      schemaTitle={schemaTitle}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      tags={tags}
      canonicalURL={canonicalURL}
      noindex={noindex}
    />
    <title>{title}</title>
    <script is:inline>
      (() => {
        try {
          const savedTheme = localStorage.getItem('theme');
          document.documentElement.dataset.theme = savedTheme === 'dark' ? 'dark' : 'light';
          document.documentElement.classList.add('js');
        } catch {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>
    <ClientRouter />
  </head>
  <body id="site-root">
    <a class="skip-link" href="#main-content">跳到主要内容</a>

    <FlowFieldBackground animated={backgroundMotion} />

    <div class="site-shell">
      <header class="site-header">
        <nav class="site-nav liquid-glass" aria-label="主导航">
          <a href="/" class="brand" aria-label="Fine 首页">
            <span class="brand-name">Fine<span aria-hidden="true">.</span></span>
            <span class="brand-note">Build · Think · Share</span>
          </a>

          <div class="nav-links" id="primary-navigation" data-active-index={activeNavIndex}>
            <span
              class="nav-tab-indicator"
              aria-hidden="true"
              transition:name="nav-tab-indicator"
            ></span>
            {navItems.map((item) => (
              <a
                href={item.href}
                class:list={{ active: isActive(item.href) }}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            ))}

            <div class="mobile-social-links" aria-label="其他链接">
              <a href="https://github.com/fine405" target="_blank" rel="noopener noreferrer">
                <GitHubIcon />
                GitHub
              </a>
              <a href="/rss.xml" target="_blank" rel="noopener noreferrer">
                <Rss size={18} stroke-width={1.8} aria-hidden="true" />
                RSS
              </a>
            </div>
          </div>

          <div class="nav-actions">
            <a
              href="https://github.com/fine405"
              target="_blank"
              rel="noopener noreferrer"
              class="icon-button desktop-social"
              aria-label="访问 Fine 的 GitHub"
              title="GitHub"
            >
              <GitHubIcon />
            </a>
            <a
              href="/rss.xml"
              target="_blank"
              rel="noopener noreferrer"
              class="icon-button desktop-social"
              aria-label="订阅 RSS"
              title="RSS 订阅"
            >
              <Rss size={17} stroke-width={1.8} aria-hidden="true" />
            </a>
            <button id="theme-toggle" class="icon-button" type="button" aria-label="切换到深色主题">
              <Moon class="moon" size={18} stroke-width={1.8} aria-hidden="true" />
              <Sun class="sun" size={18} stroke-width={1.8} aria-hidden="true" />
            </button>
            <button
              id="menu-toggle"
              class="icon-button menu-toggle"
              type="button"
              aria-label="打开菜单"
              aria-controls="primary-navigation"
              aria-expanded="false"
            >
              <Menu class="menu-icon" size={20} stroke-width={1.8} aria-hidden="true" />
              <X class="close-icon" size={20} stroke-width={1.8} aria-hidden="true" />
            </button>
          </div>
        </nav>
      </header>

      <main id="main-content" class="page-main">
        <slot />
      </main>

      <footer class="site-footer liquid-glass">
        <div>
          <a href="/" class="footer-brand">Fine<span aria-hidden="true">.</span></a>
          <p>记录 AI、工程与创造之间值得复用的经验。</p>
        </div>
        <div class="footer-meta">
          <div class="footer-links">
            <a href="/blog">文章</a>
            <a href="/tags">标签</a>
            <a href="/about">关于</a>
            <a href="/rss.xml">RSS</a>
          </div>
          <p>&copy; {new Date().getFullYear()} Fine. Built with care.</p>
        </div>
      </footer>
    </div>

    <button id="back-to-top" class="back-to-top liquid-glass" type="button" aria-label="返回页面顶部" title="返回顶部">
      <ArrowUp size={18} stroke-width={1.9} aria-hidden="true" />
    </button>

    <script is:inline>
      function initTheme() {
        const savedTheme = localStorage.getItem('theme');
        const theme = savedTheme === 'dark' ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', theme);
        updateThemeUI(theme);
      }

      function updateThemeUI(theme) {
        const themeToggle = document.getElementById('theme-toggle');
        const themeMeta = document.querySelector('meta[name="theme-color"]');
        const nextLabel = theme === 'dark' ? '切换到浅色主题' : '切换到深色主题';

        if (themeToggle) {
          themeToggle.setAttribute('aria-label', nextLabel);
          themeToggle.setAttribute('title', nextLabel);
        }
        if (themeMeta) {
          themeMeta.setAttribute('content', theme === 'dark' ? '#130f0f' : '#f4cdb6');
        }
      }

      function setupThemeToggle() {
        const themeToggle = document.getElementById('theme-toggle');
        if (!themeToggle || themeToggle.dataset.bound === 'true') return;

        themeToggle.dataset.bound = 'true';
        themeToggle.addEventListener('click', () => {
          const current = document.documentElement.getAttribute('data-theme');
          const next = current === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          localStorage.setItem('theme', next);
          updateThemeUI(next);
        });
      }

      function setupMenuToggle() {
        const menuToggle = document.getElementById('menu-toggle');
        const navLinks = document.getElementById('primary-navigation');
        if (!menuToggle || !navLinks) return;

        const closeMenu = () => {
          navLinks.classList.remove('open');
          menuToggle.classList.remove('open');
          menuToggle.setAttribute('aria-expanded', 'false');
          menuToggle.setAttribute('aria-label', '打开菜单');
          document.body.classList.remove('menu-open');
        };

        if (menuToggle.dataset.bound !== 'true') {
          menuToggle.dataset.bound = 'true';
          menuToggle.addEventListener('click', () => {
            const willOpen = !navLinks.classList.contains('open');
            navLinks.classList.toggle('open', willOpen);
            menuToggle.classList.toggle('open', willOpen);
            menuToggle.setAttribute('aria-expanded', String(willOpen));
            menuToggle.setAttribute('aria-label', willOpen ? '关闭菜单' : '打开菜单');
            document.body.classList.toggle('menu-open', willOpen);
          });
        }

        if (navLinks.dataset.bound !== 'true') {
          navLinks.dataset.bound = 'true';
          navLinks.addEventListener('click', (event) => {
            const target = event.target;
            if (target instanceof Element && target.closest('a')) closeMenu();
          });
        }

        if (window['__baseLayoutEscapeHandler']) {
          document.removeEventListener('keydown', window['__baseLayoutEscapeHandler']);
        }
        window['__baseLayoutEscapeHandler'] = (event) => {
          if (event.key === 'Escape') closeMenu();
        };
        document.addEventListener('keydown', window['__baseLayoutEscapeHandler']);
      }

      function setupBackToTop() {
        const button = document.getElementById('back-to-top');
        const header = document.querySelector('.site-header');
        if (!button) return;

        if (window['__backToTopScrollHandler']) {
          window.removeEventListener('scroll', window['__backToTopScrollHandler']);
        }
        const updateVisibility = () => {
          const isAwayFromTop = window.scrollY > 24;
          button.classList.toggle('visible', window.scrollY > 560);
          header?.classList.toggle('scrolled', isAwayFromTop);
          header?.classList.toggle('is-hidden', isAwayFromTop);
          header?.toggleAttribute('inert', isAwayFromTop);
        };
        window['__backToTopScrollHandler'] = updateVisibility;
        window.addEventListener('scroll', updateVisibility, { passive: true });
        updateVisibility();

        if (button.dataset.bound !== 'true') {
          button.dataset.bound = 'true';
          button.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
        }
      }

      function setupRevealMotion() {
        const items = document.querySelectorAll('[data-reveal]');
        if (window['__revealObserver']) {
          window['__revealObserver'].disconnect();
        }
        if (!items.length) return;

        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduceMotion || !('IntersectionObserver' in window)) {
          items.forEach((item) => item.classList.add('is-visible'));
          return;
        }

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          });
        }, {
          rootMargin: '0px 0px -8% 0px',
          threshold: 0.08,
        });

        items.forEach((item) => observer.observe(item));
        window['__revealObserver'] = observer;
      }

      function setupLiquidInteraction() {
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const finePointer = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
        const surfaces = document.querySelectorAll('.liquid-glass');

        surfaces.forEach((surface) => {
          if (surface.dataset.liquidBound === 'true') return;
          surface.dataset.liquidBound = 'true';

          surface.addEventListener('pointermove', (event) => {
            if (reduceMotion || !finePointer) return;
            const rect = surface.getBoundingClientRect();
            const x = ((event.clientX - rect.left) / rect.width) * 100;
            const y = ((event.clientY - rect.top) / rect.height) * 100;
            surface.style.setProperty('--glass-x', `${Math.max(0, Math.min(100, x))}%`);
            surface.style.setProperty('--glass-y', `${Math.max(0, Math.min(100, y))}%`);
            surface.style.setProperty('--glass-glint-opacity', '1');
          }, { passive: true });

          surface.addEventListener('pointerleave', () => {
            surface.style.removeProperty('--glass-x');
            surface.style.removeProperty('--glass-y');
            surface.style.removeProperty('--glass-glint-opacity');
          }, { passive: true });
        });

      }

      function initLayout() {
        document.body.classList.remove('menu-open');
        initTheme();
        setupThemeToggle();
        setupMenuToggle();
        setupBackToTop();
        setupRevealMotion();
        setupLiquidInteraction();
      }

      initLayout();

      if (!window['__baseLayoutPageLoadBound']) {
        document.addEventListener('astro:page-load', initLayout);
        window['__baseLayoutPageLoadBound'] = true;
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f4cdb6;
    --flow-background: #f4cdb6;
    --bg-secondary: rgba(248, 229, 218, 0.76);
    --surface: rgba(255, 255, 255, 0.7);
    --surface-solid: rgba(255, 252, 248, 0.88);
    --surface-soft: rgba(255, 255, 255, 0.42);
    --reading-surface: rgba(255, 253, 250, 0.9);
    --text: #443633;
    --text-primary: #211817;
    --text-secondary: #68534f;
    --text-tertiary: #6e5752;
    --accent: #bd5537;
    --accent-strong: #963b25;
    --accent-soft: rgba(190, 84, 53, 0.14);
    --accent-faint: rgba(190, 84, 53, 0.1);
    --primary-action-bg: linear-gradient(145deg, #b84f32, #8f321f 72%);
    --primary-action-color: #fffaf7;
    --primary-action-shadow: 0 12px 30px rgba(133, 50, 31, 0.28);
    --primary-action-shadow-hover: 0 16px 38px rgba(133, 50, 31, 0.34);
    --progress-gradient: linear-gradient(90deg, #efb06f, var(--accent), #c8492f);
    --progress-glow: rgba(185, 74, 46, 0.42);
    --nav-fill: rgba(255, 248, 242, 0.56);
    --nav-fill-strong: rgba(255, 250, 246, 0.76);
    --nav-stroke: rgba(255, 255, 255, 0.64);
    --nav-stroke-strong: rgba(190, 105, 70, 0.22);
    --nav-accent: var(--accent);
    --nav-accent-strong: var(--accent-strong);
    --nav-accent-soft: var(--accent-soft);
    --nav-tab-hover: rgba(174, 77, 46, 0.055);
    --nav-tab-active: rgba(181, 73, 42, 0.105);
    --nav-tab-active-border: rgba(156, 67, 40, 0.12);
    --nav-shadow: 0 18px 48px rgba(112, 59, 38, 0.1), 0 3px 12px rgba(112, 59, 38, 0.055);
    --nav-shadow-scrolled: 0 22px 58px rgba(103, 53, 34, 0.14), 0 5px 16px rgba(103, 53, 34, 0.07);
    --border: rgba(119, 79, 65, 0.14);
    --border-strong: rgba(111, 70, 55, 0.24);
    --glass-fill: rgba(255, 255, 255, 0.68);
    --glass-fill-strong: rgba(255, 255, 255, 0.82);
    --glass-stroke: rgba(255, 255, 255, 0.78);
    --glass-stroke-muted: rgba(255, 255, 255, 0.48);
    --glass-highlight: rgba(255, 255, 255, 0.88);
    --glass-shadow: 0 24px 64px rgba(101, 58, 42, 0.12), 0 4px 16px rgba(101, 58, 42, 0.065);
    --glass-shadow-hover: 0 30px 78px rgba(94, 52, 37, 0.16), 0 8px 22px rgba(101, 58, 42, 0.085);
    --code-bg: rgba(255, 238, 228, 0.78);
    --shadow-xs: 0 1px 2px rgba(77, 45, 34, 0.06);
    --shadow-sm: 0 10px 32px rgba(94, 55, 40, 0.11);
    --shadow-md: 0 24px 68px rgba(94, 55, 40, 0.16);
    --radius-sm: 12px;
    --radius-md: 20px;
    --radius-lg: 28px;
    --radius-xl: 36px;
    --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
    --site-cursor: url('/cursor-light.svg') 3 3, default;
  }

  [data-theme='dark'] {
    color-scheme: dark;
    --bg: #130f0f;
    --flow-background: #130f0f;
    --bg-secondary: rgba(38, 28, 28, 0.74);
    --surface: rgba(32, 25, 26, 0.58);
    --surface-solid: rgba(39, 30, 31, 0.84);
    --surface-soft: rgba(37, 28, 29, 0.42);
    --reading-surface: rgba(24, 19, 20, 0.86);
    --text: #eadfda;
    --text-primary: #fff7f2;
    --text-secondary: #c6afa6;
    --text-tertiary: #927b73;
    --accent: #ef8965;
    --accent-strong: #ffb090;
    --accent-soft: rgba(232, 102, 61, 0.18);
    --accent-faint: rgba(214, 84, 48, 0.14);
    --primary-action-bg: linear-gradient(145deg, #f0a07d, #d46f4d 72%);
    --primary-action-color: #2c1712;
    --primary-action-shadow: 0 12px 30px rgba(0, 0, 0, 0.28);
    --primary-action-shadow-hover: 0 16px 38px rgba(0, 0, 0, 0.36);
    --progress-gradient: linear-gradient(90deg, #ffd199, var(--accent), #e56543);
    --progress-glow: rgba(240, 133, 91, 0.42);
    --nav-fill: rgba(35, 24, 22, 0.54);
    --nav-fill-strong: rgba(40, 27, 25, 0.74);
    --nav-stroke: rgba(255, 221, 207, 0.13);
    --nav-stroke-strong: rgba(255, 151, 111, 0.22);
    --nav-accent: var(--accent);
    --nav-accent-strong: var(--accent-strong);
    --nav-accent-soft: var(--accent-soft);
    --nav-tab-hover: rgba(245, 139, 98, 0.065);
    --nav-tab-active: rgba(245, 139, 98, 0.13);
    --nav-tab-active-border: rgba(255, 165, 127, 0.16);
    --nav-shadow: 0 22px 56px rgba(0, 0, 0, 0.3), 0 4px 14px rgba(0, 0, 0, 0.18);
    --nav-shadow-scrolled: 0 26px 68px rgba(0, 0, 0, 0.38), 0 6px 18px rgba(0, 0, 0, 0.22);
    --border: rgba(255, 218, 201, 0.11);
    --border-strong: rgba(255, 218, 201, 0.2);
    --glass-fill: rgba(27, 21, 22, 0.46);
    --glass-fill-strong: rgba(32, 25, 26, 0.68);
    --glass-stroke: rgba(255, 225, 212, 0.18);
    --glass-stroke-muted: rgba(255, 225, 212, 0.1);
    --glass-highlight: rgba(255, 255, 255, 0.24);
    --glass-shadow: 0 28px 72px rgba(0, 0, 0, 0.34), 0 6px 18px rgba(0, 0, 0, 0.2);
    --glass-shadow-hover: 0 34px 86px rgba(0, 0, 0, 0.42), 0 8px 24px rgba(0, 0, 0, 0.25);
    --code-bg: rgba(42, 29, 28, 0.86);
    --shadow-xs: 0 1px 2px rgba(0, 0, 0, 0.12);
    --shadow-sm: 0 12px 36px rgba(0, 0, 0, 0.24);
    --shadow-md: 0 26px 76px rgba(0, 0, 0, 0.36);
    --site-cursor: url('/cursor-dark.svg') 3 3, default;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html,
  #site-root,
  #site-root *,
  #site-root *::before,
  #site-root *::after {
    cursor: var(--site-cursor) !important;
  }

  * {
    margin: 0;
    padding: 0;
  }

  html {
    background: var(--bg);
    color: var(--text);
    font-family: Inter, ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI',
      'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
    font-synthesis: none;
    scroll-behavior: smooth;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
  }

  body {
    position: relative;
    min-width: 320px;
    min-height: 100vh;
    overflow-x: clip;
    background: var(--bg);
    color: var(--text);
    transition: background-color 240ms ease, color 240ms ease;
  }

  .liquid-glass {
    --glass-x: 18%;
    --glass-y: 0%;
    --glass-glint-opacity: 0.64;
    position: relative;
    isolation: isolate;
    border: 1px solid var(--glass-stroke-muted);
    background: var(--glass-fill);
    box-shadow:
      var(--glass-shadow),
      inset 0 1px 0 var(--glass-highlight),
      inset 1px 0 0 rgba(255, 255, 255, 0.2),
      inset 0 -1px 0 rgba(116, 70, 53, 0.08);
    -webkit-backdrop-filter: blur(24px) saturate(1.35);
    backdrop-filter: blur(24px) saturate(1.35);
    corner-shape: squircle;
  }

  .liquid-glass::after {
    position: absolute;
    inset: 0;
    z-index: 2;
    border-radius: inherit;
    corner-shape: inherit;
    background:
      radial-gradient(circle at var(--glass-x) var(--glass-y), rgba(255, 255, 255, 0.72), transparent 28%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.22), transparent 34% 70%, rgba(230, 137, 98, 0.09));
    content: '';
    opacity: var(--glass-glint-opacity);
    pointer-events: none;
    transition: opacity 220ms ease;
  }

  .liquid-glass > * {
    position: relative;
    z-index: 3;
  }

  [data-theme='dark'] .liquid-glass::after {
    background:
      radial-gradient(circle at var(--glass-x) var(--glass-y), rgba(255, 255, 255, 0.2), transparent 30%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.07), transparent 38% 72%, rgba(218, 104, 65, 0.09));
  }

  body.menu-open {
    overflow: hidden;
  }

  ::selection {
    background: rgba(190, 84, 53, 0.22);
    color: var(--text-primary);
  }

  :focus-visible {
    outline: 3px solid rgba(190, 84, 53, 0.34);
    outline-offset: 3px;
    border-radius: 6px;
  }

  a,
  button {
    -webkit-tap-highlight-color: transparent;
  }

  button,
  input,
  textarea,
  select {
    font: inherit;
  }

  a {
    color: var(--accent);
    text-underline-offset: 0.18em;
  }

  .skip-link {
    position: fixed;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 1000;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    background: var(--glass-fill-strong);
    box-shadow: var(--glass-shadow);
    color: var(--text-primary);
    font-size: 0.875rem;
    font-weight: 650;
    text-decoration: none;
    transform: translateY(-160%);
    transition: transform 180ms ease;
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    backdrop-filter: blur(20px) saturate(1.3);
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .site-shell {
    position: relative;
    z-index: 1;
    width: min(1180px, calc(100% - 3rem));
    min-height: 100vh;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
  }

  .site-header {
    position: sticky;
    top: 1rem;
    z-index: 100;
    padding-top: 1rem;
    transition:
      opacity 220ms ease,
      transform 280ms var(--ease-out);
  }

  .site-header.is-hidden {
    opacity: 0;
    pointer-events: none;
    transform: translateY(-0.75rem);
  }

  .site-nav {
    min-height: 64px;
    padding: 0.48rem 0.55rem 0.48rem 1.15rem;
    display: grid;
    grid-template-columns: minmax(190px, 1fr) auto minmax(190px, 1fr);
    align-items: center;
    overflow: hidden;
    border: 1px solid var(--nav-stroke);
    border-radius: 20px;
    background: var(--nav-fill);
    box-shadow:
      var(--nav-shadow),
      inset 0 1px 0 rgba(255, 255, 255, 0.7),
