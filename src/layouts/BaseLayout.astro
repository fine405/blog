---
import SEO from '../components/SEO.astro';
import { ClientRouter } from 'astro:transitions';
import {
  ArrowUp,
  GitFork,
  Menu,
  Moon,
  Rss,
  Sun,
  X,
} from '@lucide/astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  schemaType?: 'WebSite' | 'WebPage' | 'CollectionPage' | 'AboutPage' | 'BlogPosting';
  schemaTitle?: string;
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
  canonicalURL?: string;
  noindex?: boolean;
}

const {
  title,
  description = '一个专注于开发技术的个人博客',
  image,
  imageAlt,
  type = 'website',
  schemaType,
  schemaTitle,
  publishedTime,
  modifiedTime,
  tags = [],
  canonicalURL,
  noindex = false,
} = Astro.props;

const pathname = Astro.url.pathname;
const navItems = [
  { href: '/', label: '首页' },
  { href: '/blog', label: '文章' },
  { href: '/tags', label: '标签' },
  { href: '/about', label: '关于' },
];
const isActive = (href: string) => href === '/' ? pathname === '/' : pathname.startsWith(href);
const activeNavIndex = Math.max(navItems.findIndex((item) => isActive(item.href)), 0);
---

<!doctype html>
<html lang="zh-CN" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#edf3ff" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="https://github.com/fine405.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="Fine - RSS Feed" href="/rss.xml" />
    <SEO
      title={title}
      description={description}
      image={image}
      imageAlt={imageAlt}
      type={type}
      schemaType={schemaType}
      schemaTitle={schemaTitle}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      tags={tags}
      canonicalURL={canonicalURL}
      noindex={noindex}
    />
    <title>{title}</title>
    <script is:inline>
      (() => {
        try {
          const savedTheme = localStorage.getItem('theme');
          document.documentElement.dataset.theme = savedTheme === 'dark' ? 'dark' : 'light';
          document.documentElement.classList.add('js');
        } catch {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#main-content">跳到主要内容</a>

    <div class="liquid-ambient" aria-hidden="true">
      <span class="liquid-orb liquid-orb-cobalt"></span>
      <span class="liquid-orb liquid-orb-violet"></span>
      <span class="liquid-orb liquid-orb-aqua"></span>
    </div>

    <div class="site-shell">
      <header class="site-header">
        <nav class="site-nav liquid-glass" aria-label="主导航">
          <a href="/" class="brand" aria-label="Fine 首页">
            <span class="brand-name">Fine<span aria-hidden="true">.</span></span>
            <span class="brand-note">Build · Think · Share</span>
          </a>

          <div class="nav-links" id="primary-navigation" data-active-index={activeNavIndex}>
            <span
              class="nav-tab-indicator"
              aria-hidden="true"
              transition:name="nav-tab-indicator"
            ></span>
            {navItems.map((item) => (
              <a
                href={item.href}
                class:list={{ active: isActive(item.href) }}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            ))}

            <div class="mobile-social-links" aria-label="其他链接">
              <a href="https://github.com/fine405" target="_blank" rel="noopener noreferrer">
                <GitFork size={18} stroke-width={1.8} aria-hidden="true" />
                GitHub
              </a>
              <a href="/rss.xml" target="_blank" rel="noopener noreferrer">
                <Rss size={18} stroke-width={1.8} aria-hidden="true" />
                RSS
              </a>
            </div>
          </div>

          <div class="nav-actions">
            <a
              href="https://github.com/fine405"
              target="_blank"
              rel="noopener noreferrer"
              class="icon-button desktop-social"
              aria-label="访问 Fine 的 GitHub"
              title="GitHub"
            >
              <GitFork size={18} stroke-width={1.8} aria-hidden="true" />
            </a>
            <a
              href="/rss.xml"
              target="_blank"
              rel="noopener noreferrer"
              class="icon-button desktop-social"
              aria-label="订阅 RSS"
              title="RSS 订阅"
            >
              <Rss size={17} stroke-width={1.8} aria-hidden="true" />
            </a>
            <button id="theme-toggle" class="icon-button" type="button" aria-label="切换到深色主题">
              <Moon class="moon" size={18} stroke-width={1.8} aria-hidden="true" />
              <Sun class="sun" size={18} stroke-width={1.8} aria-hidden="true" />
            </button>
            <button
              id="menu-toggle"
              class="icon-button menu-toggle"
              type="button"
              aria-label="打开菜单"
              aria-controls="primary-navigation"
              aria-expanded="false"
            >
              <Menu class="menu-icon" size={20} stroke-width={1.8} aria-hidden="true" />
              <X class="close-icon" size={20} stroke-width={1.8} aria-hidden="true" />
            </button>
          </div>
        </nav>
      </header>

      <main id="main-content" class="page-main">
        <slot />
      </main>

      <footer class="site-footer liquid-glass">
        <div>
          <a href="/" class="footer-brand">Fine<span aria-hidden="true">.</span></a>
          <p>记录 AI、工程与创造之间值得复用的经验。</p>
        </div>
        <div class="footer-meta">
          <div class="footer-links">
            <a href="/blog">文章</a>
            <a href="/tags">标签</a>
            <a href="/about">关于</a>
            <a href="/rss.xml">RSS</a>
          </div>
          <p>&copy; {new Date().getFullYear()} Fine. Built with care.</p>
        </div>
      </footer>
    </div>

    <button id="back-to-top" class="back-to-top liquid-glass" type="button" aria-label="返回页面顶部" title="返回顶部">
      <ArrowUp size={18} stroke-width={1.9} aria-hidden="true" />
    </button>

    <script is:inline>
      function initTheme() {
        const savedTheme = localStorage.getItem('theme');
        const theme = savedTheme === 'dark' ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', theme);
        updateThemeUI(theme);
      }

      function updateThemeUI(theme) {
        const themeToggle = document.getElementById('theme-toggle');
        const themeMeta = document.querySelector('meta[name="theme-color"]');
        const nextLabel = theme === 'dark' ? '切换到浅色主题' : '切换到深色主题';

        if (themeToggle) {
          themeToggle.setAttribute('aria-label', nextLabel);
          themeToggle.setAttribute('title', nextLabel);
        }
        if (themeMeta) {
          themeMeta.setAttribute('content', theme === 'dark' ? '#080d18' : '#edf3ff');
        }
      }

      function setupThemeToggle() {
        const themeToggle = document.getElementById('theme-toggle');
        if (!themeToggle || themeToggle.dataset.bound === 'true') return;

        themeToggle.dataset.bound = 'true';
        themeToggle.addEventListener('click', () => {
          const current = document.documentElement.getAttribute('data-theme');
          const next = current === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          localStorage.setItem('theme', next);
          updateThemeUI(next);
        });
      }

      function setupMenuToggle() {
        const menuToggle = document.getElementById('menu-toggle');
        const navLinks = document.getElementById('primary-navigation');
        if (!menuToggle || !navLinks) return;

        const closeMenu = () => {
          navLinks.classList.remove('open');
          menuToggle.classList.remove('open');
          menuToggle.setAttribute('aria-expanded', 'false');
          menuToggle.setAttribute('aria-label', '打开菜单');
          document.body.classList.remove('menu-open');
        };

        if (menuToggle.dataset.bound !== 'true') {
          menuToggle.dataset.bound = 'true';
          menuToggle.addEventListener('click', () => {
            const willOpen = !navLinks.classList.contains('open');
            navLinks.classList.toggle('open', willOpen);
            menuToggle.classList.toggle('open', willOpen);
            menuToggle.setAttribute('aria-expanded', String(willOpen));
            menuToggle.setAttribute('aria-label', willOpen ? '关闭菜单' : '打开菜单');
            document.body.classList.toggle('menu-open', willOpen);
          });
        }

        if (navLinks.dataset.bound !== 'true') {
          navLinks.dataset.bound = 'true';
          navLinks.addEventListener('click', (event) => {
            const target = event.target;
            if (target instanceof Element && target.closest('a')) closeMenu();
          });
        }

        if (window['__baseLayoutEscapeHandler']) {
          document.removeEventListener('keydown', window['__baseLayoutEscapeHandler']);
        }
        window['__baseLayoutEscapeHandler'] = (event) => {
          if (event.key === 'Escape') closeMenu();
        };
        document.addEventListener('keydown', window['__baseLayoutEscapeHandler']);
      }

      function setupBackToTop() {
        const button = document.getElementById('back-to-top');
        const header = document.querySelector('.site-header');
        if (!button) return;

        if (window['__backToTopScrollHandler']) {
          window.removeEventListener('scroll', window['__backToTopScrollHandler']);
        }
        const updateVisibility = () => {
          const isAwayFromTop = window.scrollY > 24;
          button.classList.toggle('visible', window.scrollY > 560);
          header?.classList.toggle('scrolled', isAwayFromTop);
          header?.classList.toggle('is-hidden', isAwayFromTop);
          header?.toggleAttribute('inert', isAwayFromTop);
        };
        window['__backToTopScrollHandler'] = updateVisibility;
        window.addEventListener('scroll', updateVisibility, { passive: true });
        updateVisibility();

        if (button.dataset.bound !== 'true') {
          button.dataset.bound = 'true';
          button.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
        }
      }

      function setupRevealMotion() {
        const items = document.querySelectorAll('[data-reveal]');
        if (window['__revealObserver']) {
          window['__revealObserver'].disconnect();
        }
        if (!items.length) return;

        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduceMotion || !('IntersectionObserver' in window)) {
          items.forEach((item) => item.classList.add('is-visible'));
          return;
        }

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          });
        }, {
          rootMargin: '0px 0px -8% 0px',
          threshold: 0.08,
        });

        items.forEach((item) => observer.observe(item));
        window['__revealObserver'] = observer;
      }

      function setupLiquidInteraction() {
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const finePointer = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
        const surfaces = document.querySelectorAll('.liquid-glass');

        surfaces.forEach((surface) => {
          if (surface.dataset.liquidBound === 'true') return;
          surface.dataset.liquidBound = 'true';

          surface.addEventListener('pointermove', (event) => {
            if (reduceMotion || !finePointer) return;
            const rect = surface.getBoundingClientRect();
            const x = ((event.clientX - rect.left) / rect.width) * 100;
            const y = ((event.clientY - rect.top) / rect.height) * 100;
            surface.style.setProperty('--glass-x', `${Math.max(0, Math.min(100, x))}%`);
            surface.style.setProperty('--glass-y', `${Math.max(0, Math.min(100, y))}%`);
            surface.style.setProperty('--glass-glint-opacity', '1');
          }, { passive: true });

          surface.addEventListener('pointerleave', () => {
            surface.style.removeProperty('--glass-x');
            surface.style.removeProperty('--glass-y');
            surface.style.removeProperty('--glass-glint-opacity');
          }, { passive: true });
        });

        if (window['__liquidAmbientPointerHandler']) {
          window.removeEventListener('pointermove', window['__liquidAmbientPointerHandler']);
          window['__liquidAmbientPointerHandler'] = undefined;
        }
        if (reduceMotion || !finePointer) return;

        let frame = 0;
        let pointerX = 0;
        let pointerY = 0;
        const paintAmbient = () => {
          document.documentElement.style.setProperty('--ambient-shift-x', `${pointerX}px`);
          document.documentElement.style.setProperty('--ambient-shift-y', `${pointerY}px`);
          frame = 0;
        };
        const handleAmbientPointer = (event) => {
          pointerX = ((event.clientX / window.innerWidth) - 0.5) * 24;
          pointerY = ((event.clientY / window.innerHeight) - 0.5) * 18;
          if (!frame) frame = window.requestAnimationFrame(paintAmbient);
        };

        window['__liquidAmbientPointerHandler'] = handleAmbientPointer;
        window.addEventListener('pointermove', handleAmbientPointer, { passive: true });
      }

      function initLayout() {
        document.body.classList.remove('menu-open');
        initTheme();
        setupThemeToggle();
        setupMenuToggle();
        setupBackToTop();
        setupRevealMotion();
        setupLiquidInteraction();
      }

      initLayout();

      if (!window['__baseLayoutPageLoadBound']) {
        document.addEventListener('astro:page-load', initLayout);
        window['__baseLayoutPageLoadBound'] = true;
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #edf3ff;
    --bg-secondary: rgba(232, 239, 252, 0.72);
    --surface: rgba(255, 255, 255, 0.56);
    --surface-solid: rgba(255, 255, 255, 0.82);
    --surface-soft: rgba(255, 255, 255, 0.34);
    --reading-surface: rgba(252, 253, 255, 0.84);
    --text: #1d293d;
    --text-primary: #0c1528;
    --text-secondary: #5d6d85;
    --text-tertiary: #8997ac;
    --accent: #4776e6;
    --accent-strong: #2f5fcf;
    --accent-soft: rgba(75, 118, 230, 0.13);
    --accent-faint: rgba(80, 122, 235, 0.12);
    --border: rgba(71, 93, 132, 0.13);
    --border-strong: rgba(65, 88, 131, 0.22);
    --glass-fill: rgba(255, 255, 255, 0.44);
    --glass-fill-strong: rgba(255, 255, 255, 0.66);
    --glass-stroke: rgba(255, 255, 255, 0.78);
    --glass-stroke-muted: rgba(255, 255, 255, 0.48);
    --glass-highlight: rgba(255, 255, 255, 0.88);
    --glass-shadow: 0 24px 64px rgba(44, 65, 108, 0.13), 0 4px 16px rgba(44, 65, 108, 0.07);
    --glass-shadow-hover: 0 30px 78px rgba(38, 61, 107, 0.17), 0 8px 22px rgba(44, 65, 108, 0.09);
    --code-bg: rgba(232, 239, 250, 0.78);
    --shadow-xs: 0 1px 2px rgba(18, 32, 58, 0.05);
    --shadow-sm: 0 10px 32px rgba(43, 62, 101, 0.1);
    --shadow-md: 0 24px 68px rgba(43, 62, 101, 0.15);
    --radius-sm: 12px;
    --radius-md: 20px;
    --radius-lg: 28px;
    --radius-xl: 36px;
    --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
    --ambient-shift-x: 0px;
    --ambient-shift-y: 0px;
  }

  [data-theme='dark'] {
    color-scheme: dark;
    --bg: #080d18;
    --bg-secondary: rgba(20, 30, 48, 0.74);
    --surface: rgba(18, 27, 44, 0.58);
    --surface-solid: rgba(22, 32, 51, 0.84);
    --surface-soft: rgba(22, 32, 51, 0.42);
    --reading-surface: rgba(12, 19, 32, 0.86);
    --text: #dce5f3;
    --text-primary: #f5f8ff;
    --text-secondary: #a9b7cb;
    --text-tertiary: #75839a;
    --accent: #8babff;
    --accent-strong: #b0c3ff;
    --accent-soft: rgba(115, 151, 255, 0.17);
    --accent-faint: rgba(91, 132, 245, 0.14);
    --border: rgba(222, 233, 255, 0.11);
    --border-strong: rgba(222, 233, 255, 0.2);
    --glass-fill: rgba(15, 24, 41, 0.46);
    --glass-fill-strong: rgba(17, 27, 46, 0.68);
    --glass-stroke: rgba(225, 236, 255, 0.18);
    --glass-stroke-muted: rgba(225, 236, 255, 0.1);
    --glass-highlight: rgba(255, 255, 255, 0.24);
    --glass-shadow: 0 28px 72px rgba(0, 0, 0, 0.34), 0 6px 18px rgba(0, 0, 0, 0.2);
    --glass-shadow-hover: 0 34px 86px rgba(0, 0, 0, 0.42), 0 8px 24px rgba(0, 0, 0, 0.25);
    --code-bg: rgba(19, 29, 47, 0.86);
    --shadow-xs: 0 1px 2px rgba(0, 0, 0, 0.12);
    --shadow-sm: 0 12px 36px rgba(0, 0, 0, 0.24);
    --shadow-md: 0 26px 76px rgba(0, 0, 0, 0.36);
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  * {
    margin: 0;
    padding: 0;
  }

  html {
    background: var(--bg);
    color: var(--text);
    font-family: Inter, ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI',
      'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
    font-synthesis: none;
    scroll-behavior: smooth;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
  }

  body {
    position: relative;
    min-width: 320px;
    min-height: 100vh;
    overflow-x: clip;
    background: var(--bg);
    color: var(--text);
    transition: background-color 240ms ease, color 240ms ease;
  }

  .liquid-ambient {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .liquid-ambient::before,
  .liquid-ambient::after {
    position: absolute;
    inset: 0;
    content: '';
  }

  .liquid-ambient::before {
    background:
      radial-gradient(circle at 12% 8%, rgba(100, 154, 255, 0.28), transparent 31rem),
      radial-gradient(circle at 88% 12%, rgba(175, 132, 255, 0.22), transparent 29rem),
      radial-gradient(circle at 54% 86%, rgba(81, 213, 209, 0.17), transparent 34rem),
      linear-gradient(140deg, rgba(255, 255, 255, 0.28), transparent 42%);
  }

  .liquid-ambient::after {
    opacity: 0.24;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.16) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.12) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.38), transparent 72%);
  }

  [data-theme='dark'] .liquid-ambient::before {
    background:
      radial-gradient(circle at 10% 5%, rgba(48, 100, 222, 0.32), transparent 32rem),
      radial-gradient(circle at 90% 10%, rgba(119, 70, 210, 0.27), transparent 30rem),
      radial-gradient(circle at 55% 90%, rgba(23, 133, 148, 0.2), transparent 34rem),
      linear-gradient(140deg, rgba(38, 55, 88, 0.2), transparent 44%);
  }

  [data-theme='dark'] .liquid-ambient::after {
    opacity: 0.08;
  }

  .liquid-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(8px);
    opacity: 0.5;
    will-change: transform;
    transition: opacity 300ms ease;
  }

  .liquid-orb-cobalt {
    top: 9%;
    left: -11rem;
    width: 31rem;
    height: 31rem;
    background: radial-gradient(circle at 65% 35%, rgba(126, 178, 255, 0.55), rgba(68, 103, 225, 0.16) 56%, transparent 72%);
    transform: translate3d(var(--ambient-shift-x), var(--ambient-shift-y), 0);
  }

  .liquid-orb-violet {
    top: 29%;
    right: -13rem;
    width: 36rem;
    height: 36rem;
    background: radial-gradient(circle at 35% 45%, rgba(201, 154, 255, 0.46), rgba(120, 89, 226, 0.14) 56%, transparent 73%);
    transform: translate3d(var(--ambient-shift-x), var(--ambient-shift-y), 0);
  }

  .liquid-orb-aqua {
    bottom: -17rem;
    left: 34%;
    width: 34rem;
    height: 34rem;
    background: radial-gradient(circle at 50% 42%, rgba(101, 224, 215, 0.35), rgba(66, 150, 208, 0.1) 58%, transparent 74%);
    transform: translate3d(var(--ambient-shift-x), var(--ambient-shift-y), 0);
  }

  [data-theme='dark'] .liquid-orb {
    opacity: 0.34;
  }

  .liquid-glass {
    --glass-x: 18%;
    --glass-y: 0%;
    --glass-glint-opacity: 0.64;
    position: relative;
    isolation: isolate;
    border: 1px solid var(--glass-stroke-muted);
    background: var(--glass-fill);
    box-shadow:
      var(--glass-shadow),
      inset 0 1px 0 var(--glass-highlight),
      inset 1px 0 0 rgba(255, 255, 255, 0.2),
      inset 0 -1px 0 rgba(67, 88, 128, 0.08);
    -webkit-backdrop-filter: blur(24px) saturate(1.35);
    backdrop-filter: blur(24px) saturate(1.35);
    corner-shape: squircle;
  }

  .liquid-glass::after {
    position: absolute;
    inset: 0;
    z-index: 2;
    border-radius: inherit;
    background:
      radial-gradient(circle at var(--glass-x) var(--glass-y), rgba(255, 255, 255, 0.72), transparent 28%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.22), transparent 34% 70%, rgba(151, 178, 255, 0.08));
    content: '';
    opacity: var(--glass-glint-opacity);
    pointer-events: none;
    transition: opacity 220ms ease;
  }

  .liquid-glass > * {
    position: relative;
    z-index: 3;
  }

  [data-theme='dark'] .liquid-glass::after {
    background:
      radial-gradient(circle at var(--glass-x) var(--glass-y), rgba(255, 255, 255, 0.2), transparent 30%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.07), transparent 38% 72%, rgba(105, 135, 224, 0.08));
  }

  body.menu-open {
    overflow: hidden;
  }

  ::selection {
    background: rgba(63, 91, 216, 0.2);
    color: var(--text-primary);
  }

  :focus-visible {
    outline: 3px solid rgba(63, 91, 216, 0.28);
    outline-offset: 3px;
    border-radius: 6px;
  }

  a,
  button {
    -webkit-tap-highlight-color: transparent;
  }

  button,
  input,
  textarea,
  select {
    font: inherit;
  }

  a {
    color: var(--accent);
    text-underline-offset: 0.18em;
  }

  .skip-link {
    position: fixed;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 1000;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    background: var(--glass-fill-strong);
    box-shadow: var(--glass-shadow);
    color: var(--text-primary);
    font-size: 0.875rem;
    font-weight: 650;
    text-decoration: none;
    transform: translateY(-160%);
    transition: transform 180ms ease;
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    backdrop-filter: blur(20px) saturate(1.3);
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .site-shell {
    position: relative;
    z-index: 1;
